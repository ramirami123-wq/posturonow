    "custom_liquid_8HbfXK": {
      "type": "custom-liquid",
      "name": "Custom Liquid",
      "settings": {
        "subheading": "",
        "title": "",
        "liquid": "{%- comment -%}\n==================================================================\n  PosturoNow — HOMEPAGE  (single Custom Liquid block)\n==================================================================\n{%- endcomment -%}\n\n{%- assign p = all_products['posture-support-belt'] -%}\n{%- unless p -%}{%- assign p = all_products.first -%}{%- endunless -%}\n\n<style>\n  #pn-home{--navy:#0A1F44;--accent:#1E6BFF;--light:#F5F8FC;--text:#475569;--border:#E2E8F0;\n    font-family:-apple-system,BlinkMacSystemFont,\"Segoe UI\",Roboto,Helvetica,Arial,sans-serif;color:var(--navy);line-height:1.6;\n    width:100vw;position:relative;left:50%;transform:translateX(-50%);margin-left:0;margin-right:0;overflow-x:hidden;}\n  #pn-home *{box-sizing:border-box;}\n  #pn-home img{max-width:100%;display:block;}\n  #pn-home .wrap{max-width:1140px;margin:0 auto;padding:0 20px;}\n  #pn-home .btn{display:inline-flex;align-items:center;justify-content:center;gap:8px;background:var(--accent);color:#fff;font-weight:700;font-size:16px;border:none;border-radius:999px;padding:15px 32px;cursor:pointer;text-decoration:none;box-shadow:0 8px 24px rgba(30,107,255,.3);transition:transform .15s,box-shadow .15s;}\n  #pn-home .btn:hover{transform:translateY(-2px);box-shadow:0 12px 30px rgba(30,107,255,.42);}\n  #pn-home .stars{color:#FBBF24;letter-spacing:2px;}\n  #pn-home .h2{font-size:32px;font-weight:800;text-align:center;margin:0 0 8px;}\n  #pn-home .lead{text-align:center;color:var(--text);max-width:620px;margin:0 auto 36px;}\n  #pn-home .sect{padding:56px 0;}\n  #pn-home .alt{background:var(--light);}\n\n  /* announcement */\n  #pn-home .ann{background:var(--navy);color:#fff;overflow:hidden;}\n  #pn-home .ann-track{display:flex;gap:60px;white-space:nowrap;padding:10px 0;animation:pn-ann 25s linear infinite;}\n  #pn-home .ann:hover .ann-track{animation-play-state:paused;}\n  #pn-home .ann span{font-size:13px;font-weight:600;letter-spacing:.4px;}\n  @keyframes pn-ann{from{transform:translateX(0);}to{transform:translateX(-50%);}}\n\n  /* header */\n  #pn-home .hdr{background:#fff;border-bottom:1px solid #EEF2F7;position:sticky;top:0;z-index:40;}\n  #pn-home .hdr-in{display:flex;align-items:center;justify-content:space-between;padding:14px 20px;max-width:1140px;margin:0 auto;}\n  #pn-home .hdr-logo{font-size:22px;font-weight:800;color:var(--navy);text-decoration:none;}\n  #pn-home .hdr-nav{display:flex;gap:26px;}\n  #pn-home .hdr-nav a{color:var(--navy);text-decoration:none;font-weight:600;font-size:15px;}\n  #pn-home .hdr-nav a:hover{color:var(--accent);}\n  #pn-home .hdr-act{display:flex;align-items:center;gap:18px;}\n  #pn-home .hdr-act a,#pn-home .hdr-act button{background:none;border:none;cursor:pointer;color:var(--navy);text-decoration:none;display:flex;padding:0;}\n  #pn-home .hdr-act svg{width:22px;height:22px;}\n  #pn-home .hdr-cart{position:relative;}\n  #pn-home .hdr-count{position:absolute;top:-8px;right:-10px;background:var(--accent);color:#fff;font-size:11px;font-weight:700;min-width:18px;height:18px;border-radius:9px;display:flex;align-items:center;justify-content:center;padding:0 4px;}\n  @media(max-width:760px){#pn-home .hdr-nav{display:none;}}\n\n  /* slideshow */\n  #pn-home .ss{position:relative;overflow:hidden;}\n  #pn-home .ss-track{display:flex;transition:transform .6s ease;}\n  #pn-home .ss-slide{min-width:100%;position:relative;}\n  #pn-home .ss-slide img{width:100%;height:560px;object-fit:cover;}\n  #pn-home .ss-ph{width:100%;height:560px;background:linear-gradient(120deg,#0A1F44,#16306b);}\n  #pn-home .ss-ov{position:absolute;inset:0;background:linear-gradient(90deg,rgba(10,31,68,.6),rgba(10,31,68,.15));}\n  #pn-home .ss-content{position:absolute;inset:0;display:flex;flex-direction:column;justify-content:center;max-width:1140px;margin:0 auto;padding:0 40px;color:#fff;}\n  #pn-home .ss-content h2{font-size:clamp(28px,5vw,52px);font-weight:800;line-height:1.1;margin:0 0 12px;max-width:600px;}\n  #pn-home .ss-content p{font-size:clamp(15px,2vw,20px);margin:0 0 22px;max-width:500px;color:#E2E8F0;}\n  #pn-home .ss-nav{position:absolute;top:50%;transform:translateY(-50%);background:rgba(255,255,255,.85);border:none;width:44px;height:44px;border-radius:50%;cursor:pointer;font-size:22px;color:var(--navy);display:flex;align-items:center;justify-content:center;}\n  #pn-home .ss-prev{left:16px;}#pn-home .ss-next{right:16px;}\n  #pn-home .ss-dots{position:absolute;bottom:18px;left:0;right:0;display:flex;justify-content:center;gap:8px;}\n  #pn-home .ss-dot{width:10px;height:10px;border-radius:50%;background:rgba(255,255,255,.5);border:none;cursor:pointer;padding:0;}\n  #pn-home .ss-dot.active{background:#fff;width:24px;border-radius:5px;}\n  @media(max-width:760px){#pn-home .ss-slide img,#pn-home .ss-ph{height:440px;}#pn-home .ss-content{text-align:center;align-items:center;padding:0 24px;}#pn-home .ss-content p{margin-inline:auto;}#pn-home .ss-nav{display:none;}}\n\n  /* featured product band */\n  #pn-home .fp{display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:center;}\n  #pn-home .fp.rev{direction:rtl;}#pn-home .fp.rev>*{direction:ltr;}\n  #pn-home .fp img{width:100%;border-radius:16px;background:var(--light);aspect-ratio:1/1;object-fit:cover;}\n  #pn-home .fp .eyebrow{color:var(--accent);font-weight:700;font-size:13px;letter-spacing:1px;text-transform:uppercase;}\n  #pn-home .fp h2{font-size:30px;font-weight:800;text-align:left;margin:8px 0 12px;}\n  #pn-home .fp p{color:var(--text);font-size:16px;margin:0 0 16px;}\n  #pn-home .fp .price{font-size:26px;font-weight:800;margin-right:10px;}\n  #pn-home .fp .compare{color:#94A3B8;text-decoration:line-through;font-size:18px;}\n  @media(max-width:760px){#pn-home .fp{grid-template-columns:1fr;gap:24px;direction:ltr;}#pn-home .fp h2{text-align:center;}}\n\n  /* section image+text checklist */\n  #pn-home .split{display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:center;}\n  #pn-home .split img{border-radius:16px;}\n  #pn-home .split h2{text-align:left;font-size:28px;}\n  #pn-home .feat{list-style:none;padding:0;margin:16px 0 0;}\n  #pn-home .feat li{display:flex;gap:12px;margin-bottom:12px;font-size:15px;}\n  #pn-home .feat .ck{color:var(--accent);font-weight:800;}\n  @media(max-width:760px){#pn-home .split{grid-template-columns:1fr;gap:24px;}#pn-home .split h2{text-align:center;}}\n\n  /* rich text band */\n  #pn-home .band{text-align:center;}\n  #pn-home .band .eyebrow{color:var(--accent);font-weight:700;font-size:13px;letter-spacing:1px;text-transform:uppercase;}\n  #pn-home .band h2{font-size:34px;margin:10px 0 16px;}\n  #pn-home .band p{color:var(--text);font-size:17px;max-width:640px;margin:0 auto;}\n\n  /* shop the look */\n  #pn-home .stl-stage{position:relative;border-radius:18px;overflow:hidden;}\n  #pn-home .stl-stage img{width:100%;display:block;}\n  #pn-home .stl-ph{width:100%;aspect-ratio:16/9;background:#CBD5E1;}\n  #pn-home .stl-dot{position:absolute;width:30px;height:30px;border-radius:50%;background:#fff;border:none;cursor:pointer;box-shadow:0 2px 10px rgba(0,0,0,.3);transform:translate(-50%,-50%);display:flex;align-items:center;justify-content:center;}\n  #pn-home .stl-dot::after{content:\"\";width:12px;height:12px;border-radius:50%;background:var(--accent);}\n  #pn-home .stl-dot::before{content:\"\";position:absolute;inset:-6px;border-radius:50%;border:2px solid rgba(30,107,255,.4);animation:stl-pulse 2s infinite;}\n  @keyframes stl-pulse{0%{transform:scale(1);opacity:.7;}100%{transform:scale(1.6);opacity:0;}}\n  #pn-home .stl-card{position:absolute;transform:translate(-50%,calc(-100% - 18px));width:230px;background:#fff;border-radius:14px;box-shadow:0 10px 30px rgba(0,0,0,.2);padding:12px;display:none;z-index:5;}\n  #pn-home .stl-card.show{display:block;}\n  #pn-home .stl-card .row{display:flex;gap:10px;align-items:center;}\n  #pn-home .stl-card img{width:54px;height:54px;border-radius:8px;object-fit:cover;}\n  #pn-home .stl-card .nm{font-weight:700;font-size:13px;color:var(--navy);text-decoration:none;display:block;}\n  #pn-home .stl-card .pr{color:var(--accent);font-weight:800;font-size:14px;}\n  #pn-home .stl-card a.go{display:block;text-align:center;margin-top:10px;background:var(--accent);color:#fff;text-decoration:none;border-radius:999px;padding:8px;font-weight:700;font-size:13px;}\n  @media(max-width:760px){#pn-home .stl-dot,#pn-home .stl-card{display:none!important;}}\n\n  /* trust icons */\n  #pn-home .trust{display:grid;grid-template-columns:repeat(4,1fr);gap:24px;}\n  #pn-home .trust .ti{text-align:center;}\n  #pn-home .trust .ti .ico{width:58px;height:58px;border-radius:50%;background:#EFF5FF;display:flex;align-items:center;justify-content:center;margin:0 auto 12px;font-size:26px;}\n  #pn-home .trust .ti h3{font-size:16px;margin:0 0 4px;}\n  #pn-home .trust .ti p{font-size:13px;color:var(--text);margin:0;}\n  @media(max-width:760px){#pn-home .trust{grid-template-columns:1fr 1fr;}}\n\n  /* footer */\n  #pn-home .ft{background:var(--navy);color:#fff;padding:54px 0 0;}\n  #pn-home .ft a{color:#fff;text-decoration:none;opacity:.85;}#pn-home .ft a:hover{opacity:1;text-decoration:underline;}\n  #pn-home .ft-grid{display:grid;grid-template-columns:1.4fr 1fr 1fr 1.2fr;gap:40px;padding-bottom:40px;}\n  #pn-home .ft .name{font-size:22px;font-weight:800;}\n  #pn-home .ft p.tag{opacity:.8;font-size:14px;max-width:280px;}\n  #pn-home .ft h4{font-size:14px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;margin:0 0 14px;}\n  #pn-home .ft ul{list-style:none;padding:0;margin:0;}#pn-home .ft li{margin-bottom:10px;font-size:14px;}\n  #pn-home .ft .news input{padding:11px 14px;border:none;border-radius:8px;font-size:14px;width:100%;margin-bottom:8px;}\n  #pn-home .ft .news button{background:var(--accent);color:#fff;border:none;border-radius:8px;padding:11px 18px;font-weight:700;cursor:pointer;width:100%;}\n  #pn-home .ft-bottom{border-top:1px solid rgba(255,255,255,.15);padding:20px 0;display:flex;flex-wrap:wrap;gap:14px;justify-content:space-between;align-items:center;}\n  #pn-home .ft-bottom p{margin:0;font-size:13px;opacity:.7;}\n  #pn-home .ft-cod span{background:rgba(255,255,255,.12);border-radius:5px;padding:4px 10px;font-size:12px;font-weight:700;}\n  @media(max-width:760px){#pn-home .ft-grid{grid-template-columns:1fr 1fr;}}\n\n  /* cart drawer */\n  #pn-home .cd-ov{position:fixed;inset:0;background:rgba(10,31,68,.45);z-index:9990;opacity:0;visibility:hidden;transition:opacity .25s;}\n  #pn-home .cd-ov.open{opacity:1;visibility:visible;}\n  #pn-home .cd{position:fixed;top:0;right:0;bottom:0;width:400px;max-width:90vw;background:#fff;z-index:9991;display:flex;flex-direction:column;transform:translateX(100%);transition:transform .3s;}\n  #pn-home .cd.open{transform:translateX(0);}\n  #pn-home .cd-head{display:flex;align-items:center;justify-content:space-between;padding:20px;border-bottom:1px solid #EEF2F7;}\n  #pn-home .cd-head h3{margin:0;font-size:18px;font-weight:800;}\n  #pn-home .cd-close{background:none;border:none;font-size:26px;cursor:pointer;color:var(--navy);}\n  #pn-home .cd-items{flex:1;overflow-y:auto;padding:16px 20px;}\n  #pn-home .cd-item{display:flex;gap:12px;padding:14px 0;border-bottom:1px solid #F1F5F9;}\n  #pn-home .cd-item img{width:62px;height:62px;object-fit:cover;border-radius:10px;background:var(--light);}\n  #pn-home .cd-title{font-weight:700;font-size:14px;color:var(--navy);text-decoration:none;}\n  #pn-home .cd-qty{display:inline-flex;align-items:center;border:1px solid var(--border);border-radius:8px;margin-top:6px;}\n  #pn-home .cd-qty button{width:28px;height:28px;border:none;background:none;cursor:pointer;font-size:16px;}\n  #pn-home .cd-qty span{width:30px;text-align:center;font-size:13px;font-weight:700;}\n  #pn-home .cd-rm{background:none;border:none;color:#94A3B8;font-size:12px;cursor:pointer;text-decoration:underline;padding:0;margin-top:4px;}\n  #pn-home .cd-foot{padding:20px;border-top:1px solid #EEF2F7;}\n  #pn-home .cd-sub{display:flex;justify-content:space-between;font-weight:800;font-size:16px;margin-bottom:6px;}\n  #pn-home .cd-co{display:block;text-align:center;background:var(--accent);color:#fff;border-radius:999px;padding:15px;font-weight:700;text-decoration:none;}\n  #pn-home .cd-empty{text-align:center;color:#94A3B8;padding:60px 20px;}\n</style>\n\n<div id=\"pn-home\">\n\n  <!-- ANNOUNCEMENT -->\n  <div class=\"ann\"><div class=\"ann-track\">\n    {%- for i in (1..2) -%}\n      <span>🚚 FREE delivery on every order</span><span>💵 Cash on Delivery available</span><span>✓ 30-day money-back guarantee</span><span>⭐ Loved by 1,200+ customers</span>\n    {%- endfor -%}\n  </div></div>\n\n  <!-- HEADER -->\n  <header class=\"hdr\"><div class=\"hdr-in\">\n    <a class=\"hdr-logo\" href=\"{{ routes.root_url }}\"><img src=\"https://cdn.shopify.com/s/files/1/0747/7071/0711/files/Screenshot_2026-06-08_134546.png?v=1780915593\" alt=\"PosturoNow\" style=\"height:40px;width:auto;display:block;\"></a>\n    <nav class=\"hdr-nav\">\n      <a href=\"{{ routes.root_url }}\">Home</a>\n      <a href=\"{{ routes.all_products_collection_url }}\">Catalog</a>\n      <a href=\"/pages/contact\">Contact</a>\n    </nav>\n    <div class=\"hdr-act\">\n      <a href=\"{{ routes.search_url }}\" aria-label=\"Search\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><circle cx=\"11\" cy=\"11\" r=\"7\"/><path d=\"m21 21-4.3-4.3\"/></svg></a>\n      <a href=\"{{ routes.account_url }}\" aria-label=\"Login\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><circle cx=\"12\" cy=\"8\" r=\"4\"/><path d=\"M4 21c0-4 4-6 8-6s8 2 8 6\"/></svg></a>\n      <button class=\"hdr-cart\" onclick=\"pnCartOpen()\" aria-label=\"Cart\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z\"/><path d=\"M3 6h18\"/><path d=\"M16 10a4 4 0 0 1-8 0\"/></svg><span class=\"hdr-count\" id=\"pn-count\">{{ cart.item_count }}</span></button>\n    </div>\n  </div></header>\n\n  <!-- SLIDESHOW -->\n  <section class=\"ss\"><div class=\"ss-track\" id=\"pn-ss-track\">\n    <div class=\"ss-slide\">\n      {%- if p.featured_image -%}<img src=\"{{ p.featured_image | image_url: width: 2000 }}\" alt=\"\">{%- else -%}<div class=\"ss-ph\"></div>{%- endif -%}\n      <div class=\"ss-ov\"></div>\n      <div class=\"ss-content\"><h2>Sit Taller. Feel Better. Every Day.</h2><p>Gentle posture support that fits into your everyday routine.</p><a class=\"btn\" href=\"{{ p.url }}\">Shop Now</a></div>\n    </div>\n    <div class=\"ss-slide\">\n      {%- if p.images[1] -%}<img src=\"{{ p.images[1] | image_url: width: 2000 }}\" alt=\"\">{%- else -%}<div class=\"ss-ph\"></div>{%- endif -%}\n      <div class=\"ss-ov\"></div>\n      <div class=\"ss-content\"><h2>Free Delivery + Cash on Delivery</h2><p>30-day money-back guarantee on every order.</p><a class=\"btn\" href=\"{{ p.url }}\">Get Yours</a></div>\n    </div>\n  </div>\n    <button class=\"ss-nav ss-prev\" onclick=\"pnSlide(-1)\" aria-label=\"Prev\">‹</button>\n    <button class=\"ss-nav ss-next\" onclick=\"pnSlide(1)\" aria-label=\"Next\">›</button>\n    <div class=\"ss-dots\"><button class=\"ss-dot active\" onclick=\"pnGoto(0)\"></button><button class=\"ss-dot\" onclick=\"pnGoto(1)\"></button></div>\n  </section>\n\n  <!-- FEATURED PRODUCT 1 -->\n  <section class=\"sect\"><div class=\"wrap\"><div class=\"fp\">\n    <div>{%- if p.featured_image -%}<img src=\"{{ p.featured_image | image_url: width:800 }}\" alt=\"\">{%- endif -%}</div>\n    <div>\n      <span class=\"eyebrow\">Best Seller</span>\n      <h2>{{ p.title | default: 'Posture Support Belt' }}</h2>\n      <p>{{ p.description | strip_html | truncatewords: 30 }}</p>\n      <div><span class=\"price\">{{ p.price | money }}</span>{%- if p.compare_at_price > p.price -%}<span class=\"compare\">{{ p.compare_at_price | money }}</span>{%- endif -%}</div>\n      <a class=\"btn\" href=\"{{ p.url }}\" style=\"margin-top:18px;\">Shop Now</a>\n    </div>\n  </div></div></section>\n\n  <!-- SECTION (image + checklist) -->\n  <section class=\"sect alt\"><div class=\"wrap\"><div class=\"split\">\n    <div>{%- if p.images[1] -%}<img src=\"{{ p.images[1] | image_url: width:700 }}\" alt=\"\">{%- elsif p.featured_image -%}<img src=\"{{ p.featured_image | image_url: width:700 }}\" alt=\"\">{%- endif -%}</div>\n    <div>\n      <span class=\"eyebrow\" style=\"color:var(--accent);font-weight:700;font-size:13px;letter-spacing:1px;text-transform:uppercase;\">Why It Works</span>\n      <h2 class=\"h2\" style=\"text-align:left;\">Comfortable Enough to Wear All Day</h2>\n      <p style=\"color:var(--text);\">Adjustable, breathable, and discreet — built to fit into your real routine.</p>\n      <ul class=\"feat\">\n        <li><span class=\"ck\">✓</span> Fully adjustable fit for all body types</li>\n        <li><span class=\"ck\">✓</span> Lightweight and breathable material</li>\n        <li><span class=\"ck\">✓</span> Discreet under shirts and jackets</li>\n        <li><span class=\"ck\">✓</span> Works best with movement and stretching</li>\n      </ul>\n    </div>\n  </div></div></section>\n\n  <!-- RICH TEXT -->\n  <section class=\"sect band\"><div class=\"wrap\">\n    <span class=\"eyebrow\">Our Promise</span>\n    <h2>Better Posture, Better Days</h2>\n    <p>PosturoNow is designed to support your posture and help you build healthier habits — gently, comfortably, and every day.</p>\n  </div></section>\n\n  <!-- SHOP THE LOOK -->\n  <section class=\"sect alt\"><div class=\"wrap\">\n    <h2 class=\"h2\">Shop the Look</h2>\n    <p class=\"lead\">Tap the dot to explore the product.</p>\n    <div class=\"stl-stage\">\n      {%- if p.images[2] -%}<img src=\"{{ p.images[2] | image_url: width:1600 }}\" alt=\"\">{%- elsif p.featured_image -%}<img src=\"{{ p.featured_image | image_url: width:1600 }}\" alt=\"\">{%- else -%}<div class=\"stl-ph\"></div>{%- endif -%}\n      <button class=\"stl-dot\" style=\"left:48%;top:45%;\" onclick=\"pnStl(0)\" aria-label=\"Hotspot\"></button>\n      <div class=\"stl-card\" id=\"pn-stl-0\" style=\"left:48%;top:45%;\">\n        <div class=\"row\">\n          {%- if p.featured_image -%}<img src=\"{{ p.featured_image | image_url: width:120 }}\" alt=\"\">{%- endif -%}\n          <div><a class=\"nm\" href=\"{{ p.url }}\">{{ p.title }}</a><span class=\"pr\">{{ p.price | money }}</span></div>\n        </div>\n        <a class=\"go\" href=\"{{ p.url }}\">View product</a>\n      </div>\n    </div>\n  </div></section>\n\n  <!-- TEXT WITH ICONS -->\n  <section class=\"sect\"><div class=\"wrap\"><div class=\"trust\">\n    <div class=\"ti\"><div class=\"ico\">🚚</div><h3>Free Delivery</h3><p>On every order, no minimum.</p></div>\n    <div class=\"ti\"><div class=\"ico\">💵</div><h3>Cash on Delivery</h3><p>Pay when it arrives.</p></div>\n    <div class=\"ti\"><div class=\"ico\">🛡️</div><h3>30-Day Guarantee</h3><p>Love it or your money back.</p></div>\n    <div class=\"ti\"><div class=\"ico\">💬</div><h3>Friendly Support</h3><p>We reply within 24 hours.</p></div>\n  </div></div></section>\n\n  <!-- FOOTER -->\n  <footer class=\"ft\"><div class=\"wrap\">\n    <div class=\"ft-grid\">\n      <div><div class=\"name\">PosturoNow</div><p class=\"tag\">Gentle posture support for your everyday routine.</p></div>\n      <div><h4>Shop</h4><ul><li><a href=\"{{ p.url }}\">Posture Belt</a></li><li><a href=\"{{ routes.all_products_collection_url }}\">Catalog</a></li></ul></div>\n      <div><h4>Help</h4><ul><li><a href=\"/pages/contact\">Contact</a></li><li><a href=\"/pages/shipping\">Shipping</a></li><li><a href=\"/pages/returns\">Returns</a></li></ul></div>\n      <div class=\"news\"><h4>Stay in touch</h4>\n        {%- form 'customer' -%}<input type=\"hidden\" name=\"contact[tags]\" value=\"newsletter,footer\"><input type=\"email\" name=\"contact[email]\" placeholder=\"Your email\" required><button type=\"submit\">Subscribe</button>{%- if form.posted_successfully? -%}<p style=\"color:#86efac;margin-top:8px;font-size:13px;\">Subscribed — thank you!</p>{%- endif -%}{%- endform -%}\n      </div>\n    </div>\n    <div class=\"ft-bottom\"><p>© {{ 'now' | date: '%Y' }} PosturoNow. All rights reserved.</p><div class=\"ft-cod\"><span>💵 Cash on Delivery</span></div></div>\n  </div></footer>\n\n  <!-- CART DRAWER -->\n  <div class=\"cd-ov\" id=\"pn-cd-ov\" onclick=\"pnCartClose()\"></div>\n  <aside class=\"cd\" id=\"pn-cd\" aria-label=\"Cart\">\n    <div class=\"cd-head\"><h3>Your Cart (<span id=\"pn-cd-count\">{{ cart.item_count }}</span>)</h3><button class=\"cd-close\" onclick=\"pnCartClose()\">×</button></div>\n    <div class=\"cd-items\" id=\"pn-cd-items\"></div><div class=\"cd-foot\" id=\"pn-cd-foot\"></div>\n  </aside>\n\n</div>\n\n<script>\n(function(){\n  function fmt(c){ return \"$\"+(c/100).toFixed(2); }\n\n  /* slideshow */\n  var i=0,n=2,track=document.getElementById(\"pn-ss-track\"),dots=document.querySelectorAll(\"#pn-home .ss-dot\");\n  function go(k){ i=(k+n)%n; track.style.transform=\"translateX(-\"+(i*100)+\"%)\"; dots.forEach(function(d,j){d.classList.toggle(\"active\",j===i);}); }\n  window.pnSlide=function(d){ go(i+d); }; window.pnGoto=function(k){ go(k); };\n  setInterval(function(){ go(i+1); },6000);\n\n  /* shop the look */\n  window.pnStl=function(idx){ var c=document.getElementById(\"pn-stl-\"+idx),open=c.classList.contains(\"show\"); document.querySelectorAll(\"#pn-home .stl-card\").forEach(function(x){x.classList.remove(\"show\");}); if(!open)c.classList.add(\"show\"); };\n  document.addEventListener(\"click\",function(e){ if(!e.target.closest(\"#pn-home .stl-dot\")&&!e.target.closest(\"#pn-home .stl-card\")) document.querySelectorAll(\"#pn-home .stl-card\").forEach(function(x){x.classList.remove(\"show\");}); });\n\n  /* cart drawer */\n  var ov=document.getElementById(\"pn-cd-ov\"),cd=document.getElementById(\"pn-cd\"),itemsEl=document.getElementById(\"pn-cd-items\"),footEl=document.getElementById(\"pn-cd-foot\");\n  function render(cart){\n    document.getElementById(\"pn-cd-count\").textContent=cart.item_count;\n    var hc=document.getElementById(\"pn-count\"); if(hc) hc.textContent=cart.item_count;\n    if(cart.item_count===0){ itemsEl.innerHTML='<div class=\"cd-empty\"><p>Your cart is empty.</p></div>'; footEl.innerHTML=\"\"; return; }\n    var h=\"\";\n    cart.items.forEach(function(it,i){\n      h+='<div class=\"cd-item\"><img src=\"'+(it.image?it.image.replace(/(\\.[a-z]+)(\\?|$)/i,\"_120x$1$2\"):\"\")+'\" alt=\"\">'\n       +'<div style=\"flex:1\"><a class=\"cd-title\" href=\"'+it.url+'\">'+it.product_title+'</a>'\n       +(it.variant_title?'<div style=\"font-size:12px;color:#94A3B8\">'+it.variant_title+'</div>':'')\n       +'<div class=\"cd-qty\"><button onclick=\"pnCartChange('+(i+1)+','+(it.quantity-1)+')\">−</button><span>'+it.quantity+'</span><button onclick=\"pnCartChange('+(i+1)+','+(it.quantity+1)+')\">+</button></div>'\n       +'<button class=\"cd-rm\" onclick=\"pnCartChange('+(i+1)+',0)\">Remove</button></div>'\n       +'<div style=\"font-weight:700\">'+fmt(it.final_line_price)+'</div></div>';\n    });\n    itemsEl.innerHTML=h;\n    footEl.innerHTML='<div class=\"cd-sub\"><span>Subtotal</span><span>'+fmt(cart.total_price)+'</span></div><p style=\"font-size:12px;color:#94A3B8;margin:0 0 14px\">Cash on delivery · taxes at checkout.</p><a class=\"cd-co\" href=\"/checkout\">Checkout</a>';\n  }\n  function refresh(){ fetch(\"/cart.js\").then(function(r){return r.json();}).then(render); }\n  window.pnCartOpen=function(){ ov.classList.add(\"open\"); cd.classList.add(\"open\"); document.body.style.overflow=\"hidden\"; refresh(); };\n  window.pnCartClose=function(){ ov.classList.remove(\"open\"); cd.classList.remove(\"open\"); document.body.style.overflow=\"\"; };\n  window.pnCartChange=function(line,qty){ fetch(\"/cart/change.js\",{method:\"POST\",headers:{\"Content-Type\":\"application/json\"},body:JSON.stringify({line:line,quantity:qty})}).then(function(r){return r.json();}).then(render); };\n  refresh();\n})();\n</script>",
        "add_vertical_spacing": false,
        "background_type": "full_width",
        "background": "rgba(0,0,0,0)",
        "text_color": "rgba(0,0,0,0)"
      }
    }
