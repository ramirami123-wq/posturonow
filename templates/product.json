    "custom_liquid_8HbfXK": {
      "type": "custom-liquid",
      "name": "Custom Liquid",
      "settings": {
        "subheading": "",
        "title": "",
        "liquid": "{%- comment -%}\n==================================================================\n  PosturoNow — PRODUCT PAGE  (single Custom Liquid block)\n==================================================================\n{%- endcomment -%}\n\n{%- assign p = product -%}\n{%- unless p -%}{%- assign p = all_products['posture-support-belt'] -%}{%- endunless -%}\n{%- assign cur = p.selected_or_first_available_variant -%}\n\n<style>\n  html,body{overflow-x:hidden;}\n  .shopify-section:has(#pn-pdp){padding:0!important;margin:0!important;}\n  #pn-pdp{--navy:#0A1F44;--accent:#1E6BFF;--light:#F5F8FC;--text:#475569;--border:#E2E8F0;\n    font-family:-apple-system,BlinkMacSystemFont,\"Segoe UI\",Roboto,Helvetica,Arial,sans-serif;color:var(--navy);line-height:1.6;\n    width:100vw;position:relative;left:50%;transform:translateX(-50%);margin-left:0;margin-right:0;overflow-x:hidden;}\n  #pn-pdp *{box-sizing:border-box;}\n  #pn-pdp img{max-width:100%;display:block;}\n  #pn-pdp .wrap{max-width:1140px;margin:0 auto;padding:0 20px;}\n  #pn-pdp .btn{display:inline-flex;align-items:center;justify-content:center;gap:8px;background:var(--accent);color:#fff;font-weight:700;font-size:16px;border:none;border-radius:999px;padding:15px 32px;cursor:pointer;text-decoration:none;box-shadow:0 8px 24px rgba(30,107,255,.3);transition:transform .15s,box-shadow .15s;width:100%;}\n  #pn-pdp .btn:hover{transform:translateY(-2px);box-shadow:0 12px 30px rgba(30,107,255,.42);}\n  #pn-pdp .btn[disabled]{background:#94A3B8;box-shadow:none;cursor:not-allowed;}\n  #pn-pdp .stars{color:#FBBF24;letter-spacing:2px;}\n  #pn-pdp .h2{font-size:32px;font-weight:800;text-align:center;margin:0 0 8px;}\n  #pn-pdp .lead{text-align:center;color:var(--text);max-width:620px;margin:0 auto 36px;}\n  #pn-pdp .sect{padding:56px 0;}\n  #pn-pdp .alt{background:var(--light);}\n\n  /* announcement + header */\n  #pn-pdp .ann{background:var(--navy);color:#fff;overflow:hidden;}\n  #pn-pdp .ann-track{display:flex;gap:60px;white-space:nowrap;padding:10px 0;animation:pn-ann 25s linear infinite;}\n  #pn-pdp .ann:hover .ann-track{animation-play-state:paused;}\n  #pn-pdp .ann span{font-size:13px;font-weight:600;letter-spacing:.4px;}\n  @keyframes pn-ann{from{transform:translateX(0);}to{transform:translateX(-50%);}}\n  #pn-pdp .hdr{background:#fff;border-bottom:1px solid #EEF2F7;position:sticky;top:0;z-index:40;}\n  #pn-pdp .hdr-in{display:flex;align-items:center;justify-content:space-between;padding:14px 20px;max-width:1140px;margin:0 auto;}\n  #pn-pdp .hdr-logo{font-size:22px;font-weight:800;color:var(--navy);text-decoration:none;}\n  #pn-pdp .hdr-nav{display:flex;gap:26px;}\n  #pn-pdp .hdr-nav a{color:var(--navy);text-decoration:none;font-weight:600;font-size:15px;}\n  #pn-pdp .hdr-nav a:hover{color:var(--accent);}\n  #pn-pdp .hdr-act{display:flex;align-items:center;gap:18px;}\n  #pn-pdp .hdr-act a,#pn-pdp .hdr-act button{background:none;border:none;cursor:pointer;color:var(--navy);text-decoration:none;display:flex;padding:0;}\n  #pn-pdp .hdr-act svg{width:22px;height:22px;}\n  #pn-pdp .hdr-cart{position:relative;}\n  #pn-pdp .hdr-count{position:absolute;top:-8px;right:-10px;background:var(--accent);color:#fff;font-size:11px;font-weight:700;min-width:18px;height:18px;border-radius:9px;display:flex;align-items:center;justify-content:center;padding:0 4px;}\n  @media(max-width:760px){#pn-pdp .hdr-nav{display:none;}}\n\n  /* breadcrumb */\n  #pn-pdp .crumb{font-size:13px;color:#94A3B8;padding:16px 0 0;}\n  #pn-pdp .crumb a{color:#94A3B8;text-decoration:none;}#pn-pdp .crumb a:hover{color:var(--accent);}\n\n  /* product content */\n  #pn-pdp .pc{display:grid;grid-template-columns:1fr 1fr;gap:48px;padding:24px 0 56px;align-items:start;}\n  #pn-pdp .gallery .main{border-radius:16px;background:var(--light);aspect-ratio:1/1;object-fit:cover;width:100%;}\n  #pn-pdp .thumbs{display:flex;gap:10px;margin-top:12px;flex-wrap:wrap;}\n  #pn-pdp .thumbs img{width:74px;height:74px;object-fit:cover;border-radius:10px;border:2px solid var(--border);cursor:pointer;background:var(--light);}\n  #pn-pdp .thumbs img.active{border-color:var(--accent);}\n  #pn-pdp .pc h1{font-size:34px;font-weight:800;margin:6px 0 12px;}\n  #pn-pdp .price-row{display:flex;align-items:center;gap:12px;margin-bottom:6px;flex-wrap:wrap;}\n  #pn-pdp .price{font-size:30px;font-weight:800;color:#E11D48;}\n  #pn-pdp .compare{font-size:19px;color:#94A3B8;text-decoration:line-through;}\n  #pn-pdp .sale-badge{background:var(--navy);color:#fff;font-weight:800;font-size:12px;padding:5px 10px;border-radius:6px;letter-spacing:.5px;}\n  #pn-pdp .pc-desc{color:var(--text);font-size:15px;margin:14px 0;}\n  #pn-pdp .countdown{background:var(--light);border:1px solid var(--border);border-radius:12px;padding:14px 16px;text-align:center;margin:16px 0;}\n  #pn-pdp .countdown .cd-label{font-size:13px;font-weight:700;margin-bottom:8px;}\n  #pn-pdp .countdown .cd-clock{display:flex;justify-content:center;align-items:center;gap:8px;}\n  #pn-pdp .countdown .cd-unit{background:var(--navy);color:#fff;border-radius:8px;min-width:54px;padding:8px 6px;}\n  #pn-pdp .countdown .cd-num{font-size:22px;font-weight:800;line-height:1;}\n  #pn-pdp .countdown .cd-cap{font-size:10px;opacity:.7;text-transform:uppercase;letter-spacing:.5px;}\n  #pn-pdp .countdown .cd-sep{font-size:20px;font-weight:800;color:var(--navy);}\n  #pn-pdp .opt{margin:14px 0;}\n  #pn-pdp .opt label{display:block;font-weight:700;font-size:13px;margin-bottom:7px;}\n  #pn-pdp .swatches{display:flex;flex-wrap:wrap;gap:8px;}\n  #pn-pdp .swatch{border:2px solid var(--border);border-radius:10px;padding:9px 16px;cursor:pointer;font-weight:600;font-size:14px;background:#fff;}\n  #pn-pdp .swatch.active{border-color:var(--accent);background:#EFF5FF;color:var(--accent);}\n  #pn-pdp .qty{display:inline-flex;align-items:center;border:2px solid var(--border);border-radius:10px;overflow:hidden;}\n  #pn-pdp .qty button{width:42px;height:42px;border:none;background:#fff;font-size:20px;cursor:pointer;}\n  #pn-pdp .qty input{width:46px;height:42px;text-align:center;border:none;font-size:16px;font-weight:700;-moz-appearance:textfield;}\n  #pn-pdp .qty input::-webkit-outer-spin-button,#pn-pdp .qty input::-webkit-inner-spin-button{-webkit-appearance:none;margin:0;}\n  #pn-pdp .delivery{display:flex;align-items:center;gap:8px;font-size:13px;color:var(--text);background:var(--light);border-radius:10px;padding:10px 14px;margin-top:14px;}\n  #pn-pdp .delivery svg{width:18px;height:18px;color:var(--accent);flex:none;}\n  #pn-pdp .delivery b{color:var(--navy);}\n  #pn-pdp .pc-badges{display:flex;flex-wrap:wrap;gap:16px;margin-top:16px;}\n  #pn-pdp .pc-badges .b{display:flex;align-items:center;gap:7px;font-size:13px;font-weight:600;color:var(--text);}\n  #pn-pdp .pc-badges svg{width:18px;height:18px;color:var(--accent);}\n  @media(max-width:760px){#pn-pdp .pc{grid-template-columns:1fr;gap:24px;}#pn-pdp .pc h1{font-size:28px;}}\n\n  /* related products */\n  #pn-pdp .rel{display:grid;grid-template-columns:repeat(4,1fr);gap:20px;}\n  #pn-pdp .rel a{text-decoration:none;color:var(--navy);}\n  #pn-pdp .rel .card{border:1px solid var(--border);border-radius:14px;overflow:hidden;background:#fff;transition:box-shadow .15s;}\n  #pn-pdp .rel .card:hover{box-shadow:0 10px 26px rgba(0,0,0,.08);}\n  #pn-pdp .rel .card img{width:100%;aspect-ratio:1/1;object-fit:cover;background:var(--light);}\n  #pn-pdp .rel .card .body{padding:12px;}\n  #pn-pdp .rel .card .nm{font-weight:700;font-size:14px;}\n  #pn-pdp .rel .card .pr{color:var(--accent);font-weight:800;font-size:14px;margin-top:4px;}\n  @media(max-width:760px){#pn-pdp .rel{grid-template-columns:1fr 1fr;}}\n\n  /* split image+text */\n  #pn-pdp .split{display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:center;}\n  #pn-pdp .split.rev{direction:rtl;}#pn-pdp .split.rev>*{direction:ltr;}\n  #pn-pdp .split img{border-radius:16px;}\n  #pn-pdp .split h2{text-align:left;font-size:28px;}\n  #pn-pdp .split .eyebrow{color:var(--accent);font-weight:700;font-size:13px;letter-spacing:1px;text-transform:uppercase;}\n  #pn-pdp .feat{list-style:none;padding:0;margin:16px 0 0;}\n  #pn-pdp .feat li{display:flex;gap:12px;margin-bottom:12px;font-size:15px;}\n  #pn-pdp .feat .ck{color:var(--accent);font-weight:800;}\n  @media(max-width:760px){#pn-pdp .split{grid-template-columns:1fr;gap:24px;direction:ltr;}#pn-pdp .split h2{text-align:center;}}\n\n  /* comparison table */\n  #pn-pdp .cmp{max-width:820px;margin:0 auto;}\n  #pn-pdp .cmp-table{width:100%;border-collapse:separate;border-spacing:0;}\n  #pn-pdp .cmp-table th,#pn-pdp .cmp-table td{padding:16px 14px;text-align:center;font-size:14px;}\n  #pn-pdp .cmp-table th:first-child,#pn-pdp .cmp-table td:first-child{text-align:left;font-weight:600;color:var(--navy);}\n  #pn-pdp .cmp-table thead th{font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:var(--text);}\n  #pn-pdp .cmp-table thead th.us{background:var(--navy);color:#fff;border-radius:10px 10px 0 0;font-size:13px;}\n  #pn-pdp .cmp-table td.us{background:#EFF5FF;color:var(--accent);font-weight:800;}\n  #pn-pdp .cmp-table tbody tr:last-child td.us{border-radius:0 0 10px 10px;}\n  #pn-pdp .cmp-table td.other{color:#94A3B8;font-weight:700;}\n  #pn-pdp .cmp-table tbody tr td:first-child,#pn-pdp .cmp-table tbody tr td.other{border-bottom:1px solid var(--border);}\n  #pn-pdp .cmp-table tbody tr:last-child td{border-bottom:none;}\n\n  /* reviews */\n  #pn-pdp .revs{max-width:820px;margin:0 auto;}\n  #pn-pdp .revs-summary{display:flex;align-items:center;gap:32px;background:var(--light);border-radius:16px;padding:28px 32px;margin-bottom:32px;flex-wrap:wrap;}\n  #pn-pdp .revs-big{text-align:center;}\n  #pn-pdp .revs-big .num{font-size:64px;font-weight:800;color:var(--navy);line-height:1;}\n  #pn-pdp .revs-big .stars{font-size:22px;margin:4px 0;}\n  #pn-pdp .revs-big p{font-size:13px;color:var(--text);margin:0;}\n  #pn-pdp .revs-bars{flex:1;min-width:200px;}\n  #pn-pdp .rev-bar-row{display:flex;align-items:center;gap:10px;margin-bottom:6px;font-size:13px;}\n  #pn-pdp .rev-bar-row span:first-child{width:32px;text-align:right;color:var(--text);}\n  #pn-pdp .rev-bar-track{flex:1;height:8px;background:#E2E8F0;border-radius:4px;overflow:hidden;}\n  #pn-pdp .rev-bar-fill{height:100%;background:#FBBF24;border-radius:4px;}\n  #pn-pdp .rev-bar-row span:last-child{width:28px;color:var(--text);}\n  #pn-pdp .rev-card{border:1px solid var(--border);border-radius:14px;padding:20px;background:#fff;margin-bottom:16px;}\n  #pn-pdp .rev-card .rev-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:8px;flex-wrap:wrap;gap:8px;}\n  #pn-pdp .rev-card .rev-name{font-weight:700;font-size:15px;}\n  #pn-pdp .rev-card .rev-date{font-size:12px;color:#94A3B8;}\n  #pn-pdp .rev-card .rev-stars{color:#FBBF24;font-size:15px;margin-bottom:6px;}\n  #pn-pdp .rev-card .rev-title{font-weight:700;font-size:14px;margin-bottom:4px;}\n  #pn-pdp .rev-card .rev-body{color:var(--text);font-size:14px;}\n  #pn-pdp .rev-card .rev-badge{display:inline-flex;align-items:center;gap:4px;font-size:11px;color:#16A34A;font-weight:700;margin-top:10px;}\n\n  /* faq */\n  #pn-pdp .faq{max-width:760px;margin:0 auto;}\n  #pn-pdp .faq-item{border:1px solid var(--border);border-radius:12px;margin-bottom:12px;overflow:hidden;background:#fff;}\n  #pn-pdp .faq-q{width:100%;text-align:left;background:none;border:none;padding:18px 20px;font-size:16px;font-weight:700;cursor:pointer;display:flex;justify-content:space-between;align-items:center;color:var(--navy);}\n  #pn-pdp .faq-q .pl{font-size:22px;transition:transform .2s;}\n  #pn-pdp .faq-a{padding:0 20px;max-height:0;overflow:hidden;transition:max-height .25s,padding .25s;color:var(--text);font-size:15px;}\n  #pn-pdp .faq-item.open .faq-a{padding:0 20px 18px;max-height:400px;}\n  #pn-pdp .faq-item.open .pl{transform:rotate(45deg);}\n\n  /* trust icons */\n  #pn-pdp .trust{display:grid;grid-template-columns:repeat(4,1fr);gap:24px;}\n  #pn-pdp .trust .ti{text-align:center;}\n  #pn-pdp .trust .ti .ico{width:58px;height:58px;border-radius:50%;background:#EFF5FF;display:flex;align-items:center;justify-content:center;margin:0 auto 12px;font-size:26px;}\n  #pn-pdp .trust .ti h3{font-size:16px;margin:0 0 4px;}#pn-pdp .trust .ti p{font-size:13px;color:var(--text);margin:0;}\n  @media(max-width:760px){#pn-pdp .trust{grid-template-columns:1fr 1fr;}}\n\n  /* footer */\n  #pn-pdp .ft{background:var(--navy);color:#fff;padding:54px 0 0;}\n  #pn-pdp .ft a{color:#fff;text-decoration:none;opacity:.85;}#pn-pdp .ft a:hover{opacity:1;text-decoration:underline;}\n  #pn-pdp .ft-grid{display:grid;grid-template-columns:1.4fr 1fr 1fr 1.2fr;gap:40px;padding-bottom:40px;}\n  #pn-pdp .ft .name{font-size:22px;font-weight:800;}#pn-pdp .ft p.tag{opacity:.8;font-size:14px;max-width:280px;}\n  #pn-pdp .ft h4{font-size:14px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;margin:0 0 14px;}\n  #pn-pdp .ft ul{list-style:none;padding:0;margin:0;}#pn-pdp .ft li{margin-bottom:10px;font-size:14px;}\n  #pn-pdp .ft .news input{padding:11px 14px;border:none;border-radius:8px;font-size:14px;width:100%;margin-bottom:8px;}\n  #pn-pdp .ft .news button{background:var(--accent);color:#fff;border:none;border-radius:8px;padding:11px 18px;font-weight:700;cursor:pointer;width:100%;}\n  #pn-pdp .ft-bottom{border-top:1px solid rgba(255,255,255,.15);padding:20px 0;display:flex;flex-wrap:wrap;gap:14px;justify-content:space-between;align-items:center;}\n  #pn-pdp .ft-bottom p{margin:0;font-size:13px;opacity:.7;}\n  #pn-pdp .ft-cod span{background:rgba(255,255,255,.12);border-radius:5px;padding:4px 10px;font-size:12px;font-weight:700;}\n  @media(max-width:760px){#pn-pdp .ft-grid{grid-template-columns:1fr 1fr;}}\n\n  /* sticky atc */\n  #pn-pdp .sticky{position:fixed;left:0;right:0;bottom:0;z-index:50;background:#fff;border-top:1px solid var(--border);box-shadow:0 -4px 20px rgba(0,0,0,.08);transform:translateY(110%);transition:transform .3s;}\n  #pn-pdp .sticky.show{transform:translateY(0);}\n  #pn-pdp .sticky-in{display:flex;align-items:center;justify-content:space-between;gap:16px;padding:12px 20px;max-width:1140px;margin:0 auto;}\n  #pn-pdp .sticky .sname{font-weight:800;font-size:15px;}#pn-pdp .sticky .sprice{color:var(--accent);font-weight:800;}\n  #pn-pdp .sticky .btn{width:auto;padding:12px 26px;font-size:15px;}\n  @media(max-width:600px){#pn-pdp .sticky .sname{display:none;}}\n\n  /* cart drawer */\n  #pn-pdp .cd-ov{position:fixed;inset:0;background:rgba(10,31,68,.45);z-index:9990;opacity:0;visibility:hidden;transition:opacity .25s;}\n  #pn-pdp .cd-ov.open{opacity:1;visibility:visible;}\n  #pn-pdp .cd{position:fixed;top:0;right:0;bottom:0;width:400px;max-width:90vw;background:#fff;z-index:9991;display:flex;flex-direction:column;transform:translateX(100%);transition:transform .3s;}\n  #pn-pdp .cd.open{transform:translateX(0);}\n  #pn-pdp .cd-head{display:flex;align-items:center;justify-content:space-between;padding:20px;border-bottom:1px solid #EEF2F7;}\n  #pn-pdp .cd-head h3{margin:0;font-size:18px;font-weight:800;}\n  #pn-pdp .cd-close{background:none;border:none;font-size:26px;cursor:pointer;color:var(--navy);}\n  #pn-pdp .cd-items{flex:1;overflow-y:auto;padding:16px 20px;}\n  #pn-pdp .cd-item{display:flex;gap:12px;padding:14px 0;border-bottom:1px solid #F1F5F9;}\n  #pn-pdp .cd-item img{width:62px;height:62px;object-fit:cover;border-radius:10px;background:var(--light);}\n  #pn-pdp .cd-title{font-weight:700;font-size:14px;color:var(--navy);text-decoration:none;}\n  #pn-pdp .cd-qty{display:inline-flex;align-items:center;border:1px solid var(--border);border-radius:8px;margin-top:6px;}\n  #pn-pdp .cd-qty button{width:28px;height:28px;border:none;background:none;cursor:pointer;font-size:16px;}\n  #pn-pdp .cd-qty span{width:30px;text-align:center;font-size:13px;font-weight:700;}\n  #pn-pdp .cd-rm{background:none;border:none;color:#94A3B8;font-size:12px;cursor:pointer;text-decoration:underline;padding:0;margin-top:4px;}\n  #pn-pdp .cd-foot{padding:20px;border-top:1px solid #EEF2F7;}\n  #pn-pdp .cd-sub{display:flex;justify-content:space-between;font-weight:800;font-size:16px;margin-bottom:6px;}\n  #pn-pdp .cd-co{display:block;text-align:center;background:var(--accent);color:#fff;border-radius:999px;padding:15px;font-weight:700;text-decoration:none;}\n  #pn-pdp .cd-empty{text-align:center;color:#94A3B8;padding:60px 20px;}\n</style>\n\n<div id=\"pn-pdp\">\n\n  <!-- ANNOUNCEMENT -->\n  <div class=\"ann\"><div class=\"ann-track\">\n    {%- for i in (1..2) -%}\n      <span>🚚 FREE delivery on every order</span><span>💵 Cash on Delivery available</span><span>✓ 30-day money-back guarantee</span><span>⭐ Loved by 1,200+ customers</span>\n    {%- endfor -%}\n  </div></div>\n\n  <!-- HEADER -->\n  <header class=\"hdr\"><div class=\"hdr-in\">\n    <a class=\"hdr-logo\" href=\"{{ routes.root_url }}\"><img src=\"https://cdn.shopify.com/s/files/1/0747/7071/0711/files/Screenshot_2026-06-08_134546.png?v=1780915593\" alt=\"PosturoNow\" style=\"height:50px;width:auto;display:block;max-width:200px;\"></a>\n    <nav class=\"hdr-nav\">\n      <a href=\"{{ routes.root_url }}\">Home</a>\n      <a href=\"{{ routes.all_products_collection_url }}\">Catalog</a>\n      <a href=\"/pages/contact\">Contact</a>\n    </nav>\n    <div class=\"hdr-act\">\n      <a href=\"{{ routes.search_url }}\" aria-label=\"Search\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><circle cx=\"11\" cy=\"11\" r=\"7\"/><path d=\"m21 21-4.3-4.3\"/></svg></a>\n      <a href=\"{{ routes.account_url }}\" aria-label=\"Login\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><circle cx=\"12\" cy=\"8\" r=\"4\"/><path d=\"M4 21c0-4 4-6 8-6s8 2 8 6\"/></svg></a>\n      <button class=\"hdr-cart\" onclick=\"pnCartOpen()\" aria-label=\"Cart\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z\"/><path d=\"M3 6h18\"/><path d=\"M16 10a4 4 0 0 1-8 0\"/></svg><span class=\"hdr-count\" id=\"pn-count\">{{ cart.item_count }}</span></button>\n    </div>\n  </div></header>\n\n  <!-- PRODUCT CONTENT -->\n  <div class=\"wrap\">\n    <div class=\"crumb\"><a href=\"{{ routes.root_url }}\">Home</a> / {{ p.title }}</div>\n    <div class=\"pc\">\n      <div class=\"gallery\">\n        {%- if p.featured_image -%}\n          <img class=\"main\" id=\"pn-main\" src=\"{{ p.featured_image | image_url: width:900 }}\" alt=\"{{ p.title | escape }}\">\n          {%- if p.images.size > 1 -%}\n            <div class=\"thumbs\">\n              {%- for img in p.images limit:6 -%}\n                <img src=\"{{ img | image_url: width:160 }}\" class=\"{% if forloop.first %}active{% endif %}\" onclick=\"pnSwap('{{ img | image_url: width:900 }}',this)\" alt=\"\">\n              {%- endfor -%}\n            </div>\n          {%- endif -%}\n        {%- else -%}<div class=\"main\"></div>{%- endif -%}\n      </div>\n\n      <div class=\"info\">\n        <span class=\"stars\">★★★★★</span> <span style=\"color:#94A3B8;font-size:13px;font-weight:600;\">4.9 · 1,200+ reviews</span>\n        <h1>{{ p.title | default: 'Posture Support Belt' }}</h1>\n\n        {%- form 'product', p, id:'pn-form' -%}\n          <div class=\"price-row\">\n            <span class=\"price\" id=\"pn-price\">{{ cur.price | money }}</span>\n            {%- if cur.compare_at_price > cur.price -%}\n              <span class=\"compare\">{{ cur.compare_at_price | money }}</span>\n              {%- assign diff = cur.compare_at_price | minus: cur.price -%}\n              {%- assign pct = diff | times:100 | divided_by: cur.compare_at_price -%}\n              <span class=\"sale-badge\">SALE {{ pct }}% OFF</span>\n            {%- endif -%}\n          </div>\n          <p class=\"pc-desc\">{{ p.description | strip_html | truncatewords: 40 }}</p>\n\n          <div class=\"countdown\">\n            <div class=\"cd-label\">⏰ Hurry! Sale ends in</div>\n            <div class=\"cd-clock\">\n              <div class=\"cd-unit\"><div class=\"cd-num\" id=\"pn-cd-h\">00</div><div class=\"cd-cap\">Hrs</div></div><span class=\"cd-sep\">:</span>\n              <div class=\"cd-unit\"><div class=\"cd-num\" id=\"pn-cd-m\">00</div><div class=\"cd-cap\">Min</div></div><span class=\"cd-sep\">:</span>\n              <div class=\"cd-unit\"><div class=\"cd-num\" id=\"pn-cd-s\">00</div><div class=\"cd-cap\">Sec</div></div>\n            </div>\n          </div>\n\n          {%- unless p.has_only_default_variant -%}\n            {%- for opt in p.options_with_values -%}\n              <div class=\"opt\"><label>{{ opt.name }}</label>\n                <div class=\"swatches\">\n                  {%- for val in opt.values -%}\n                    <div class=\"swatch {% if opt.selected_value == val %}active{% endif %}\" data-value=\"{{ val | escape }}\" onclick=\"pnOpt(this,{{ forloop.parentloop.index0 }})\">{{ val }}</div>\n                  {%- endfor -%}\n                </div>\n              </div>\n            {%- endfor -%}\n          {%- endunless -%}\n          <select name=\"id\" id=\"pn-sel\" style=\"display:none;\">\n            {%- for v in p.variants -%}\n              <option value=\"{{ v.id }}\" {% if v == cur %}selected{% endif %} {% unless v.available %}disabled{% endunless %} data-price=\"{{ v.price | money }}\" {% for o in v.options %}data-opt{{ forloop.index0 }}=\"{{ o | escape }}\"{% endfor %}>{{ v.title }}</option>\n            {%- endfor -%}\n          </select>\n\n          <div class=\"opt\"><label>Quantity</label>\n            <div class=\"qty\"><button type=\"button\" onclick=\"pnQty(-1)\">−</button><input type=\"number\" name=\"quantity\" id=\"pn-qty\" value=\"1\" min=\"1\"><button type=\"button\" onclick=\"pnQty(1)\">+</button></div>\n          </div>\n\n          <button type=\"submit\" class=\"btn\" id=\"pn-atc\" {% unless cur.available %}disabled{% endunless %}>{% if cur.available %}Add to Cart — {{ cur.price | money }}{% else %}Sold Out{% endif %}</button>\n\n          <div class=\"delivery\">\n            <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M1 3h15v13H1zM16 8h4l3 3v5h-7\"/><circle cx=\"5.5\" cy=\"18.5\" r=\"2.5\"/><circle cx=\"18.5\" cy=\"18.5\" r=\"2.5\"/></svg>\n            <span>Order now to receive by <b id=\"pn-delivery\">—</b></span>\n          </div>\n          <div class=\"pc-badges\">\n            <span class=\"b\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M12 2 4 5v6c0 5 3.5 8.5 8 11 4.5-2.5 8-6 8-11V5l-8-3z\"/></svg> Secure checkout</span>\n            <span class=\"b\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><rect x=\"2\" y=\"6\" width=\"20\" height=\"12\" rx=\"2\"/><path d=\"M2 10h20\"/></svg> Cash on delivery</span>\n            <span class=\"b\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><circle cx=\"12\" cy=\"12\" r=\"9\"/><path d=\"M9 12l2 2 4-4\"/></svg> 30-day guarantee</span>\n          </div>\n        {%- endform -%}\n      </div>\n    </div>\n  </div>\n\n  <!-- RELATED PRODUCTS -->\n  {%- assign coll = p.collections.first -%}\n  {%- if coll and coll.products.size > 1 -%}\n  <section class=\"sect alt\"><div class=\"wrap\">\n    <h2 class=\"h2\">You May Also Like</h2><p class=\"lead\">More from our collection.</p>\n    <div class=\"rel\">\n      {%- assign shown = 0 -%}\n      {%- for rp in coll.products -%}\n        {%- if rp.id != p.id and shown < 4 -%}\n          {%- assign shown = shown | plus: 1 -%}\n          <a href=\"{{ rp.url }}\"><div class=\"card\">\n            <img src=\"{{ rp.featured_image | image_url: width:400 }}\" alt=\"{{ rp.title | escape }}\">\n            <div class=\"body\"><div class=\"nm\">{{ rp.title | truncate: 40 }}</div><div class=\"pr\">{{ rp.price | money }}</div></div>\n          </div></a>\n        {%- endif -%}\n      {%- endfor -%}\n    </div>\n  </div></section>\n  {%- endif -%}\n\n  <!-- SECTION (image + checklist) -->\n  <section class=\"sect\"><div class=\"wrap\"><div class=\"split\">\n    <div>{%- if p.images[1] -%}<img src=\"{{ p.images[1] | image_url: width:700 }}\" alt=\"\">{%- elsif p.featured_image -%}<img src=\"{{ p.featured_image | image_url: width:700 }}\" alt=\"\">{%- endif -%}</div>\n    <div>\n      <span class=\"eyebrow\">Why It Works</span>\n      <h2>Comfortable Enough to Wear All Day</h2>\n      <p style=\"color:var(--text);\">Adjustable, breathable, and discreet — built to fit into your real routine.</p>\n      <ul class=\"feat\">\n        <li><span class=\"ck\">✓</span> Fully adjustable fit for all body types</li>\n        <li><span class=\"ck\">✓</span> Lightweight and breathable material</li>\n        <li><span class=\"ck\">✓</span> Discreet under shirts and jackets</li>\n        <li><span class=\"ck\">✓</span> Works best with movement and stretching</li>\n      </ul>\n    </div>\n  </div></div></section>\n\n  <!-- COMPARISON TABLE -->\n  <section class=\"sect alt\"><div class=\"wrap\">\n    <h2 class=\"h2\">PosturoNow vs Other Brands</h2><p class=\"lead\">See why thousands choose PosturoNow.</p>\n    <div class=\"cmp\"><table class=\"cmp-table\">\n      <thead><tr><th></th><th class=\"us\">PosturoNow</th><th>Others</th></tr></thead>\n      <tbody>\n        <tr><td>Gentle, adjustable support</td><td class=\"us\">✓ Yes</td><td class=\"other\">✕ No</td></tr>\n        <tr><td>Lightweight & breathable</td><td class=\"us\">✓ Yes</td><td class=\"other\">✕ No</td></tr>\n        <tr><td>Discreet under clothing</td><td class=\"us\">✓ Yes</td><td class=\"other\">✕ No</td></tr>\n        <tr><td>Built for all-day comfort</td><td class=\"us\">✓ Yes</td><td class=\"other\">✕ No</td></tr>\n        <tr><td>Free delivery + cash on delivery</td><td class=\"us\">✓ Yes</td><td class=\"other\">✕ No</td></tr>\n        <tr><td>30-day money-back guarantee</td><td class=\"us\">✓ Yes</td><td class=\"other\">✕ No</td></tr>\n      </tbody>\n    </table></div>\n  </div></section>\n\n  <!-- FAQ -->\n  <section class=\"sect\"><div class=\"wrap\">\n    <h2 class=\"h2\">Frequently Asked Questions</h2>\n    <div class=\"faq\" style=\"margin-top:28px;\">\n      <div class=\"faq-item\"><button class=\"faq-q\" onclick=\"pnFaq(this)\">Is it comfortable to wear? <span class=\"pl\">+</span></button><div class=\"faq-a\">Yes — it's lightweight and adjustable, designed to be worn comfortably during your daily routine.</div></div>\n      <div class=\"faq-item\"><button class=\"faq-q\" onclick=\"pnFaq(this)\">How long should I wear it each day? <span class=\"pl\">+</span></button><div class=\"faq-a\">Start with 1–2 hours a day and increase gradually. It works best combined with movement and stretching.</div></div>\n      <div class=\"faq-item\"><button class=\"faq-q\" onclick=\"pnFaq(this)\">Will it fit me? <span class=\"pl\">+</span></button><div class=\"faq-a\">The fully adjustable straps fit most body types comfortably.</div></div>\n      <div class=\"faq-item\"><button class=\"faq-q\" onclick=\"pnFaq(this)\">Can I pay cash on delivery? <span class=\"pl\">+</span></button><div class=\"faq-a\">Yes — cash on delivery is available. You pay when your order arrives.</div></div>\n      <div class=\"faq-item\"><button class=\"faq-q\" onclick=\"pnFaq(this)\">What is your return policy? <span class=\"pl\">+</span></button><div class=\"faq-a\">We offer a 30-day money-back guarantee. If you're not satisfied, contact us for a full refund.</div></div>\n    </div>\n  </div></section>\n\n  <!-- REVIEWS -->\n  <section class=\"sect alt\"><div class=\"wrap\">\n    <h2 class=\"h2\">What Customers Are Saying</h2>\n    <p class=\"lead\">Over 1,200 happy customers and counting.</p>\n    <div class=\"revs\">\n      <div class=\"revs-summary\">\n        <div class=\"revs-big\">\n          <div class=\"num\">4.9</div>\n          <div class=\"stars\">★★★★★</div>\n          <p>1,200+ reviews</p>\n        </div>\n        <div class=\"revs-bars\">\n          <div class=\"rev-bar-row\"><span>5 ★</span><div class=\"rev-bar-track\"><div class=\"rev-bar-fill\" style=\"width:88%\"></div></div><span>88%</span></div>\n          <div class=\"rev-bar-row\"><span>4 ★</span><div class=\"rev-bar-track\"><div class=\"rev-bar-fill\" style=\"width:8%\"></div></div><span>8%</span></div>\n          <div class=\"rev-bar-row\"><span>3 ★</span><div class=\"rev-bar-track\"><div class=\"rev-bar-fill\" style=\"width:2%\"></div></div><span>2%</span></div>\n          <div class=\"rev-bar-row\"><span>2 ★</span><div class=\"rev-bar-track\"><div class=\"rev-bar-fill\" style=\"width:1%\"></div></div><span>1%</span></div>\n          <div class=\"rev-bar-row\"><span>1 ★</span><div class=\"rev-bar-track\"><div class=\"rev-bar-fill\" style=\"width:1%\"></div></div><span>1%</span></div>\n        </div>\n      </div>\n\n      <div class=\"rev-card\">\n        <div class=\"rev-head\"><span class=\"rev-name\">Sarah M.</span><span class=\"rev-date\">May 2025</span></div>\n        <div class=\"rev-stars\">★★★★★</div>\n        <div class=\"rev-title\">Actually works — and I've tried everything</div>\n        <div class=\"rev-body\">I've had back problems for years from sitting at a desk all day. After two weeks of wearing this a few hours a day, I genuinely notice a difference in how I sit. It's lightweight and you completely forget you have it on.</div>\n        <span class=\"rev-badge\">✔ Verified Purchase</span>\n      </div>\n\n      <div class=\"rev-card\">\n        <div class=\"rev-head\"><span class=\"rev-name\">Karim T.</span><span class=\"rev-date\">April 2025</span></div>\n        <div class=\"rev-stars\">★★★★★</div>\n        <div class=\"rev-title\">Great product, fast delivery</div>\n        <div class=\"rev-body\">Ordered cash on delivery, arrived in 3 days. The belt is sturdy but not bulky — fits perfectly under my shirt. My posture has noticeably improved since I started using it consistently.</div>\n        <span class=\"rev-badge\">✔ Verified Purchase</span>\n      </div>\n\n      <div class=\"rev-card\">\n        <div class=\"rev-head\"><span class=\"rev-name\">Lina H.</span><span class=\"rev-date\">March 2025</span></div>\n        <div class=\"rev-stars\">★★★★★</div>\n        <div class=\"rev-title\">Comfortable enough to wear all day</div>\n        <div class=\"rev-body\">I was worried it would be uncomfortable or too rigid but it's genuinely easy to wear. I put it on in the morning and it reminds me to sit up straight without being annoying. Really happy with this purchase.</div>\n        <span class=\"rev-badge\">✔ Verified Purchase</span>\n      </div>\n\n      <div class=\"rev-card\">\n        <div class=\"rev-head\"><span class=\"rev-name\">Omar R.</span><span class=\"rev-date\">February 2025</span></div>\n        <div class=\"rev-stars\">★★★★☆</div>\n        <div class=\"rev-title\">Good quality, takes getting used to</div>\n        <div class=\"rev-body\">Took about a week to get used to wearing it but now I don't even notice it. Build quality feels solid. Would recommend starting with short sessions and building up. Customer support was also very responsive.</div>\n        <span class=\"rev-badge\">✔ Verified Purchase</span>\n      </div>\n\n    </div>\n  </div></section>\n\n  <!-- TEXT WITH ICONS -->\n  <section class=\"sect alt\"><div class=\"wrap\"><div class=\"trust\">\n    <div class=\"ti\"><div class=\"ico\">🚚</div><h3>Free Delivery</h3><p>On every order, no minimum.</p></div>\n    <div class=\"ti\"><div class=\"ico\">💵</div><h3>Cash on Delivery</h3><p>Pay when it arrives.</p></div>\n    <div class=\"ti\"><div class=\"ico\">🛡️</div><h3>30-Day Guarantee</h3><p>Love it or your money back.</p></div>\n    <div class=\"ti\"><div class=\"ico\">💬</div><h3>Friendly Support</h3><p>We reply within 24 hours.</p></div>\n  </div></div></section>\n\n  <!-- FOOTER -->\n  <footer class=\"ft\"><div class=\"wrap\">\n    <div class=\"ft-grid\">\n      <div><div class=\"name\">PosturoNow</div><p class=\"tag\">Gentle posture support for your everyday routine.</p></div>\n      <div><h4>Shop</h4><ul><li><a href=\"{{ p.url }}\">Posture Belt</a></li><li><a href=\"{{ routes.all_products_collection_url }}\">Catalog</a></li></ul></div>\n      <div><h4>Help</h4><ul><li><a href=\"/pages/contact\">Contact</a></li><li><a href=\"/pages/shipping\">Shipping</a></li><li><a href=\"/pages/returns\">Returns</a></li></ul></div>\n      <div class=\"news\"><h4>Stay in touch</h4>\n        {%- form 'customer' -%}<input type=\"hidden\" name=\"contact[tags]\" value=\"newsletter,footer\"><input type=\"email\" name=\"contact[email]\" placeholder=\"Your email\" required><button type=\"submit\">Subscribe</button>{%- if form.posted_successfully? -%}<p style=\"color:#86efac;margin-top:8px;font-size:13px;\">Subscribed — thank you!</p>{%- endif -%}{%- endform -%}\n      </div>\n    </div>\n    <div class=\"ft-bottom\"><p>© {{ 'now' | date: '%Y' }} PosturoNow. All rights reserved.</p><div class=\"ft-cod\"><span>💵 Cash on Delivery</span></div></div>\n  </div></footer>\n\n  <!-- STICKY ATC -->\n  <div class=\"sticky\" id=\"pn-sticky\"><div class=\"sticky-in\">\n    <div><span class=\"sname\">{{ p.title }}</span> <span class=\"sprice\" id=\"pn-sprice\">{{ cur.price | money }}</span></div>\n    <button type=\"submit\" form=\"pn-form\" class=\"btn\">Add to Cart</button>\n  </div></div>\n\n  <!-- CART DRAWER -->\n  <div class=\"cd-ov\" id=\"pn-cd-ov\" onclick=\"pnCartClose()\"></div>\n  <aside class=\"cd\" id=\"pn-cd\" aria-label=\"Cart\">\n    <div class=\"cd-head\"><h3>Your Cart (<span id=\"pn-cd-count\">{{ cart.item_count }}</span>)</h3><button class=\"cd-close\" onclick=\"pnCartClose()\">×</button></div>\n    <div class=\"cd-items\" id=\"pn-cd-items\"></div><div class=\"cd-foot\" id=\"pn-cd-foot\"></div>\n  </aside>\n\n</div>\n\n<script>\n(function(){\n  var COUNTDOWN_HOURS = 12;\n  function fmt(c){ return \"$\"+(c/100).toFixed(2); }\n\n  /* gallery + qty */\n  window.pnSwap=function(src,el){ document.getElementById(\"pn-main\").src=src; el.parentNode.querySelectorAll(\"img\").forEach(function(i){i.classList.remove(\"active\");}); el.classList.add(\"active\"); };\n  window.pnQty=function(d){ var i=document.getElementById(\"pn-qty\"); i.value=Math.max(1,(parseInt(i.value)||1)+d); };\n\n  /* variants */\n  var sel=document.getElementById(\"pn-sel\");\n  window.pnOpt=function(el,gi){\n    el.parentNode.querySelectorAll(\".swatch\").forEach(function(s){s.classList.remove(\"active\");}); el.classList.add(\"active\");\n    if(!sel) return;\n    var groups=document.querySelectorAll(\"#pn-pdp .swatches\"),chosen=[];\n    groups.forEach(function(g){var a=g.querySelector(\".swatch.active\");chosen.push(a?a.getAttribute(\"data-value\"):null);});\n    for(var i=0;i<sel.options.length;i++){\n      var ok=true;\n      for(var k=0;k<chosen.length;k++){ if(chosen[k]&&sel.options[i].getAttribute(\"data-opt\"+k)!==chosen[k]){ok=false;break;} }\n      if(ok){ sel.selectedIndex=i; var pr=sel.options[i].getAttribute(\"data-price\"),dis=sel.options[i].disabled;\n        document.getElementById(\"pn-price\").textContent=pr; var sp=document.getElementById(\"pn-sprice\"); if(sp) sp.textContent=pr;\n        var b=document.getElementById(\"pn-atc\"); if(b){ b.disabled=dis; b.textContent=dis?\"Sold Out\":(\"Add to Cart — \"+pr); } break; }\n    }\n  };\n\n  /* faq */\n  window.pnFaq=function(b){ b.parentNode.classList.toggle(\"open\"); };\n\n  /* countdown (evergreen) */\n  (function(){\n    var hEl=document.getElementById(\"pn-cd-h\"),mEl=document.getElementById(\"pn-cd-m\"),sEl=document.getElementById(\"pn-cd-s\"); if(!hEl) return;\n    var key=\"pn-deadline\",dl=parseInt(localStorage.getItem(key));\n    if(!dl||isNaN(dl)||dl<Date.now()){ dl=Date.now()+COUNTDOWN_HOURS*3600*1000; localStorage.setItem(key,dl); }\n    function pad(n){ return n<10?\"0\"+n:\"\"+n; }\n    function tick(){ var diff=Math.max(0,dl-Date.now()),s=Math.floor(diff/1000);\n      hEl.textContent=pad(Math.floor(s/3600)); mEl.textContent=pad(Math.floor(s%3600/60)); sEl.textContent=pad(s%60);\n      if(diff<=0){ dl=Date.now()+COUNTDOWN_HOURS*3600*1000; localStorage.setItem(key,dl); } }\n    tick(); setInterval(tick,1000);\n  })();\n\n  /* delivery estimate */\n  (function(){ var el=document.getElementById(\"pn-delivery\"); if(!el) return;\n    var o={weekday:\"long\",month:\"long\",day:\"numeric\"},a=new Date(Date.now()+2*864e5),b=new Date(Date.now()+4*864e5);\n    el.textContent=a.toLocaleDateString(undefined,o)+\" – \"+b.toLocaleDateString(undefined,o); })();\n\n  /* sticky bar */\n  var atc=document.getElementById(\"pn-atc\"),sticky=document.getElementById(\"pn-sticky\");\n  if(atc&&sticky){ window.addEventListener(\"scroll\",function(){ var r=atc.getBoundingClientRect(); sticky.classList.toggle(\"show\",r.bottom<0); },{passive:true}); }\n\n  /* cart drawer */\n  var ov=document.getElementById(\"pn-cd-ov\"),cd=document.getElementById(\"pn-cd\"),itemsEl=document.getElementById(\"pn-cd-items\"),footEl=document.getElementById(\"pn-cd-foot\");\n  function render(cart){\n    document.getElementById(\"pn-cd-count\").textContent=cart.item_count;\n    var hc=document.getElementById(\"pn-count\"); if(hc) hc.textContent=cart.item_count;\n    if(cart.item_count===0){ itemsEl.innerHTML='<div class=\"cd-empty\"><p>Your cart is empty.</p></div>'; footEl.innerHTML=\"\"; return; }\n    var h=\"\";\n    cart.items.forEach(function(it,i){\n      h+='<div class=\"cd-item\"><img src=\"'+(it.image?it.image.replace(/(\\.[a-z]+)(\\?|$)/i,\"_120x$1$2\"):\"\")+'\" alt=\"\">'\n       +'<div style=\"flex:1\"><a class=\"cd-title\" href=\"'+it.url+'\">'+it.product_title+'</a>'\n       +(it.variant_title?'<div style=\"font-size:12px;color:#94A3B8\">'+it.variant_title+'</div>':'')\n       +'<div class=\"cd-qty\"><button onclick=\"pnCartChange('+(i+1)+','+(it.quantity-1)+')\">−</button><span>'+it.quantity+'</span><button onclick=\"pnCartChange('+(i+1)+','+(it.quantity+1)+')\">+</button></div>'\n       +'<button class=\"cd-rm\" onclick=\"pnCartChange('+(i+1)+',0)\">Remove</button></div>'\n       +'<div style=\"font-weight:700\">'+fmt(it.final_line_price)+'</div></div>';\n    });\n    itemsEl.innerHTML=h;\n    footEl.innerHTML='<div class=\"cd-sub\"><span>Subtotal</span><span>'+fmt(cart.total_price)+'</span></div><p style=\"font-size:12px;color:#94A3B8;margin:0 0 14px\">Cash on delivery · taxes at checkout.</p><a class=\"cd-co\" href=\"/checkout\">Checkout</a>';\n  }\n  function refresh(){ fetch(\"/cart.js\").then(function(r){return r.json();}).then(render); }\n  window.pnCartOpen=function(){ ov.classList.add(\"open\"); cd.classList.add(\"open\"); document.body.style.overflow=\"hidden\"; refresh(); };\n  window.pnCartClose=function(){ ov.classList.remove(\"open\"); cd.classList.remove(\"open\"); document.body.style.overflow=\"\"; };\n  window.pnCartChange=function(line,qty){ fetch(\"/cart/change.js\",{method:\"POST\",headers:{\"Content-Type\":\"application/json\"},body:JSON.stringify({line:line,quantity:qty})}).then(function(r){return r.json();}).then(render); };\n  document.addEventListener(\"submit\",function(e){ if(e.target.id===\"pn-form\"){ e.preventDefault(); fetch(\"/cart/add.js\",{method:\"POST\",body:new FormData(e.target)}).then(function(r){return r.json();}).then(function(){ pnCartOpen(); }); } });\n  refresh();\n})();\n</script>",
        "add_vertical_spacing": false,
        "background_type": "full_width",
        "background": "rgba(0,0,0,0)",
        "text_color": "rgba(0,0,0,0)"
      }
    }
  },
