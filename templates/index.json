    "custom_liquid_V46k7d": {
      "type": "custom-liquid",
      "name": "Custom Liquid",
      "settings": {
        "subheading": "",
        "title": "",
        "liquid": "{%- comment -%}\n==================================================================\n  PosturoNow — FULL HOMEPAGE in ONE Custom Liquid block\n  Paste into: Online Store > Themes > Customize > Add section\n              > \"Custom Liquid\" > paste everything below.\n  Set your product handle on the next line if different.\n==================================================================\n{%- endcomment -%}\n\n{%- assign p = all_products['posture-support-belt'] -%}\n{%- unless p -%}{%- assign p = all_products.first -%}{%- endunless -%}\n{%- assign cur = p.selected_or_first_available_variant -%}\n\n<style>\n  #pn-home{ --navy:#0A1F44; --accent:#1E6BFF; --light:#F5F8FC; --text:#475569; --border:#E2E8F0;\n    font-family:-apple-system,BlinkMacSystemFont,\"Segoe UI\",Roboto,Helvetica,Arial,sans-serif; color:var(--navy); line-height:1.6;}\n  #pn-home *{box-sizing:border-box;}\n  #pn-home img{max-width:100%;display:block;}\n  #pn-home .wrap{max-width:1140px;margin:0 auto;padding:0 20px;}\n  #pn-home .btn{display:inline-flex;align-items:center;justify-content:center;gap:8px;background:var(--accent);color:#fff;font-weight:700;\n    font-size:16px;border:none;border-radius:999px;padding:15px 32px;cursor:pointer;text-decoration:none;box-shadow:0 8px 24px rgba(30,107,255,.3);transition:transform .15s,box-shadow .15s;}\n  #pn-home .btn:hover{transform:translateY(-2px);box-shadow:0 12px 30px rgba(30,107,255,.42);}\n  #pn-home .btn[disabled]{background:#94A3B8;box-shadow:none;cursor:not-allowed;}\n  #pn-home .stars{color:#FBBF24;letter-spacing:2px;}\n  #pn-home .h2{font-size:32px;font-weight:800;text-align:center;margin:0 0 8px;}\n  #pn-home .lead{text-align:center;color:var(--text);max-width:620px;margin:0 auto 36px;}\n  #pn-home .sect{padding:56px 0;}\n  #pn-home .alt{background:var(--light);}\n\n  /* announcement */\n  #pn-home .ann{background:var(--navy);color:#fff;overflow:hidden;}\n  #pn-home .ann-track{display:flex;gap:60px;white-space:nowrap;padding:10px 0;animation:pn-ann 25s linear infinite;}\n  #pn-home .ann:hover .ann-track{animation-play-state:paused;}\n  #pn-home .ann span{font-size:13px;font-weight:600;letter-spacing:.4px;}\n  @keyframes pn-ann{from{transform:translateX(0);}to{transform:translateX(-50%);}}\n\n  /* header */\n  #pn-home .hdr{background:#fff;border-bottom:1px solid #EEF2F7;position:sticky;top:0;z-index:40;}\n  #pn-home .hdr-in{display:flex;align-items:center;justify-content:space-between;padding:14px 20px;max-width:1140px;margin:0 auto;}\n  #pn-home .hdr-logo{font-size:22px;font-weight:800;color:var(--navy);text-decoration:none;display:flex;align-items:center;gap:8px;}\n  #pn-home .hdr-nav{display:flex;gap:26px;}\n  #pn-home .hdr-nav a{color:var(--navy);text-decoration:none;font-weight:600;font-size:15px;}\n  #pn-home .hdr-nav a:hover{color:var(--accent);}\n  #pn-home .hdr-cart{background:none;border:none;cursor:pointer;color:var(--navy);position:relative;display:flex;padding:0;}\n  #pn-home .hdr-cart svg{width:24px;height:24px;}\n  #pn-home .hdr-count{position:absolute;top:-8px;right:-10px;background:var(--accent);color:#fff;font-size:11px;font-weight:700;min-width:18px;height:18px;border-radius:9px;display:flex;align-items:center;justify-content:center;padding:0 4px;}\n  @media(max-width:760px){#pn-home .hdr-nav{display:none;}}\n\n  /* hero */\n  #pn-home .hero{position:relative;background:linear-gradient(120deg,#0A1F44,#16306b);color:#fff;}\n  #pn-home .hero-grid{display:grid;grid-template-columns:1.1fr 1fr;gap:40px;align-items:center;padding:60px 0;}\n  #pn-home .hero h1{font-size:clamp(30px,4.5vw,50px);font-weight:800;line-height:1.12;margin:14px 0 14px;}\n  #pn-home .hero p.sub{font-size:18px;color:#CBD5E1;margin:0 0 26px;max-width:480px;}\n  #pn-home .hero .hero-img{border-radius:18px;background:rgba(255,255,255,.06);aspect-ratio:1/1;object-fit:cover;width:100%;}\n  #pn-home .hero .badges{display:flex;gap:18px;flex-wrap:wrap;margin-top:22px;}\n  #pn-home .hero .badge{display:flex;align-items:center;gap:7px;font-size:13px;font-weight:600;color:#E2E8F0;}\n  #pn-home .hero .badge svg{width:18px;height:18px;color:#7FB0FF;}\n  @media(max-width:760px){#pn-home .hero-grid{grid-template-columns:1fr;text-align:center;padding:40px 0;}#pn-home .hero .badges{justify-content:center;}#pn-home .hero p.sub{margin-inline:auto;}}\n\n  /* trust icons */\n  #pn-home .trust{display:grid;grid-template-columns:repeat(4,1fr);gap:24px;}\n  #pn-home .trust .ti{text-align:center;}\n  #pn-home .trust .ti .ico{width:58px;height:58px;border-radius:50%;background:#EFF5FF;display:flex;align-items:center;justify-content:center;margin:0 auto 12px;font-size:26px;}\n  #pn-home .trust .ti h3{font-size:16px;margin:0 0 4px;}\n  #pn-home .trust .ti p{font-size:13px;color:var(--text);margin:0;}\n  @media(max-width:760px){#pn-home .trust{grid-template-columns:1fr 1fr;}}\n\n  /* product buy block */\n  #pn-home .buy-grid{display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:center;}\n  #pn-home .gallery .main{border-radius:16px;background:var(--light);aspect-ratio:1/1;object-fit:cover;width:100%;}\n  #pn-home .thumbs{display:flex;gap:10px;margin-top:12px;}\n  #pn-home .thumbs img{width:74px;height:74px;object-fit:cover;border-radius:10px;border:2px solid var(--border);cursor:pointer;background:var(--light);}\n  #pn-home .thumbs img.active{border-color:var(--accent);}\n  #pn-home .buy h2{font-size:30px;font-weight:800;margin:8px 0 10px;text-align:left;}\n  #pn-home .price-row{display:flex;align-items:baseline;gap:12px;margin:6px 0;}\n  #pn-home .price{font-size:32px;font-weight:800;}\n  #pn-home .compare{font-size:19px;color:#94A3B8;text-decoration:line-through;}\n  #pn-home .save{background:#DCFCE7;color:#15803D;font-weight:700;font-size:12px;padding:4px 10px;border-radius:999px;}\n  #pn-home .ship{color:#15803D;font-weight:600;font-size:14px;margin-bottom:16px;}\n  #pn-home .opt{margin-bottom:14px;}\n  #pn-home .opt label{display:block;font-weight:700;font-size:13px;margin-bottom:7px;}\n  #pn-home .swatches{display:flex;flex-wrap:wrap;gap:8px;}\n  #pn-home .swatch{border:2px solid var(--border);border-radius:10px;padding:9px 16px;cursor:pointer;font-weight:600;font-size:14px;background:#fff;}\n  #pn-home .swatch.active{border-color:var(--accent);background:#EFF5FF;color:var(--accent);}\n  #pn-home .qty{display:inline-flex;align-items:center;border:2px solid var(--border);border-radius:10px;overflow:hidden;}\n  #pn-home .qty button{width:42px;height:42px;border:none;background:#fff;font-size:20px;cursor:pointer;}\n  #pn-home .qty input{width:46px;height:42px;text-align:center;border:none;font-size:16px;font-weight:700;-moz-appearance:textfield;}\n  #pn-home .qty input::-webkit-outer-spin-button,#pn-home .qty input::-webkit-inner-spin-button{-webkit-appearance:none;margin:0;}\n  #pn-home .buy .btn{width:100%;margin-top:6px;}\n  @media(max-width:760px){#pn-home .buy-grid{grid-template-columns:1fr;gap:24px;}#pn-home .buy h2{text-align:center;}}\n\n  /* split section */\n  #pn-home .split{display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:center;}\n  #pn-home .split img{border-radius:16px;}\n  #pn-home .split h2{text-align:left;font-size:28px;}\n  #pn-home .feat{list-style:none;padding:0;margin:16px 0 0;}\n  #pn-home .feat li{display:flex;gap:12px;margin-bottom:12px;font-size:15px;}\n  #pn-home .feat .ck{color:var(--accent);font-weight:800;}\n  @media(max-width:760px){#pn-home .split{grid-template-columns:1fr;gap:24px;}}\n\n  /* reviews */\n  #pn-home .reviews{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;}\n  #pn-home .rev{background:#fff;border:1px solid var(--border);border-radius:16px;padding:24px;}\n  #pn-home .rev p{font-size:14px;margin:10px 0 14px;}\n  #pn-home .rev .who{font-weight:700;font-size:14px;}\n  #pn-home .rev .ver{color:#15803D;font-size:12px;font-weight:600;}\n  @media(max-width:760px){#pn-home .reviews{grid-template-columns:1fr;}}\n\n  /* rich text band */\n  #pn-home .band{text-align:center;}\n  #pn-home .band .eyebrow{color:var(--accent);font-weight:700;font-size:13px;letter-spacing:1px;text-transform:uppercase;}\n  #pn-home .band h2{font-size:34px;margin:10px 0 16px;}\n  #pn-home .band p{color:var(--text);font-size:17px;max-width:640px;margin:0 auto;}\n\n  /* faq */\n  #pn-home .faq{max-width:760px;margin:0 auto;}\n  #pn-home .faq-item{border:1px solid var(--border);border-radius:12px;margin-bottom:12px;overflow:hidden;background:#fff;}\n  #pn-home .faq-q{width:100%;text-align:left;background:none;border:none;padding:18px 20px;font-size:16px;font-weight:700;cursor:pointer;display:flex;justify-content:space-between;align-items:center;color:var(--navy);}\n  #pn-home .faq-q .pl{font-size:22px;transition:transform .2s;}\n  #pn-home .faq-a{padding:0 20px;max-height:0;overflow:hidden;transition:max-height .25s,padding .25s;color:var(--text);font-size:15px;}\n  #pn-home .faq-item.open .faq-a{padding:0 20px 18px;max-height:400px;}\n  #pn-home .faq-item.open .pl{transform:rotate(45deg);}\n\n  /* cta */\n  #pn-home .cta{background:var(--navy);color:#fff;border-radius:16px;padding:48px;text-align:center;}\n  #pn-home .cta h2{font-size:30px;margin:0 0 10px;color:#fff;}\n  #pn-home .cta p{color:#CBD5E1;max-width:560px;margin:0 auto 26px;}\n\n  /* footer */\n  #pn-home .ft{background:var(--navy);color:#fff;padding:54px 0 0;}\n  #pn-home .ft a{color:#fff;text-decoration:none;opacity:.85;}\n  #pn-home .ft a:hover{opacity:1;text-decoration:underline;}\n  #pn-home .ft-grid{display:grid;grid-template-columns:1.4fr 1fr 1fr 1.2fr;gap:40px;padding-bottom:40px;}\n  #pn-home .ft .name{font-size:22px;font-weight:800;}\n  #pn-home .ft p.tag{opacity:.8;font-size:14px;max-width:280px;}\n  #pn-home .ft h4{font-size:14px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;margin:0 0 14px;}\n  #pn-home .ft ul{list-style:none;padding:0;margin:0;}\n  #pn-home .ft li{margin-bottom:10px;font-size:14px;}\n  #pn-home .ft .news input{padding:11px 14px;border:none;border-radius:8px;font-size:14px;width:100%;margin-bottom:8px;}\n  #pn-home .ft .news button{background:var(--accent);color:#fff;border:none;border-radius:8px;padding:11px 18px;font-weight:700;cursor:pointer;width:100%;}\n  #pn-home .ft-bottom{border-top:1px solid rgba(255,255,255,.15);padding:20px 0;display:flex;flex-wrap:wrap;gap:14px;justify-content:space-between;align-items:center;}\n  #pn-home .ft-bottom p{margin:0;font-size:13px;opacity:.7;}\n  #pn-home .ft-pay span{background:rgba(255,255,255,.12);border-radius:5px;padding:4px 8px;font-size:11px;font-weight:700;margin-left:6px;}\n  @media(max-width:760px){#pn-home .ft-grid{grid-template-columns:1fr 1fr;}}\n\n  /* popup */\n  #pn-home .pop{position:fixed;inset:0;background:rgba(10,31,68,.55);z-index:9998;display:none;align-items:center;justify-content:center;padding:20px;}\n  #pn-home .pop.show{display:flex;}\n  #pn-home .pop-box{background:#fff;border-radius:18px;max-width:420px;width:100%;padding:30px;text-align:center;position:relative;box-shadow:0 20px 60px rgba(0,0,0,.3);}\n  #pn-home .pop-box h3{font-size:24px;font-weight:800;margin:0 0 8px;}\n  #pn-home .pop-box p{color:var(--text);margin:0 0 16px;}\n  #pn-home .pop-box input{width:100%;padding:14px;border:2px solid var(--border);border-radius:10px;font-size:15px;margin-bottom:10px;}\n  #pn-home .pop-box .btn{width:100%;}\n  #pn-home .pop-close{position:absolute;top:12px;right:14px;background:none;border:none;font-size:24px;cursor:pointer;color:var(--navy);line-height:1;}\n\n  /* privacy */\n  #pn-home .priv{position:fixed;left:0;right:0;bottom:0;z-index:9997;background:var(--navy);color:#fff;padding:16px 20px;box-shadow:0 -4px 24px rgba(0,0,0,.18);display:none;}\n  #pn-home .priv.show{display:block;}\n  #pn-home .priv-in{max-width:1140px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;gap:18px;flex-wrap:wrap;}\n  #pn-home .priv-in p{margin:0;font-size:14px;flex:1;min-width:240px;}\n  #pn-home .priv-btns{display:flex;gap:10px;}\n  #pn-home .priv-btns button{border-radius:999px;padding:10px 22px;font-weight:700;font-size:14px;cursor:pointer;border:none;}\n  #pn-home .priv-dec{background:transparent;color:#fff;border:1px solid #fff!important;}\n  #pn-home .priv-acc{background:var(--accent);color:#fff;}\n\n  /* cart drawer */\n  #pn-home .cd-ov{position:fixed;inset:0;background:rgba(10,31,68,.45);z-index:9990;opacity:0;visibility:hidden;transition:opacity .25s;}\n  #pn-home .cd-ov.open{opacity:1;visibility:visible;}\n  #pn-home .cd{position:fixed;top:0;right:0;bottom:0;width:400px;max-width:90vw;background:#fff;z-index:9991;display:flex;flex-direction:column;transform:translateX(100%);transition:transform .3s;}\n  #pn-home .cd.open{transform:translateX(0);}\n  #pn-home .cd-head{display:flex;align-items:center;justify-content:space-between;padding:20px;border-bottom:1px solid #EEF2F7;}\n  #pn-home .cd-head h3{margin:0;font-size:18px;font-weight:800;}\n  #pn-home .cd-close{background:none;border:none;font-size:26px;cursor:pointer;color:var(--navy);}\n  #pn-home .cd-items{flex:1;overflow-y:auto;padding:16px 20px;}\n  #pn-home .cd-item{display:flex;gap:12px;padding:14px 0;border-bottom:1px solid #F1F5F9;}\n  #pn-home .cd-item img{width:62px;height:62px;object-fit:cover;border-radius:10px;background:var(--light);}\n  #pn-home .cd-title{font-weight:700;font-size:14px;color:var(--navy);text-decoration:none;}\n  #pn-home .cd-qty{display:inline-flex;align-items:center;border:1px solid var(--border);border-radius:8px;margin-top:6px;}\n  #pn-home .cd-qty button{width:28px;height:28px;border:none;background:none;cursor:pointer;font-size:16px;}\n  #pn-home .cd-qty span{width:30px;text-align:center;font-size:13px;font-weight:700;}\n  #pn-home .cd-rm{background:none;border:none;color:#94A3B8;font-size:12px;cursor:pointer;text-decoration:underline;padding:0;margin-top:4px;}\n  #pn-home .cd-foot{padding:20px;border-top:1px solid #EEF2F7;}\n  #pn-home .cd-sub{display:flex;justify-content:space-between;font-weight:800;font-size:16px;margin-bottom:6px;}\n  #pn-home .cd-free{background:#DCFCE7;color:#15803D;font-size:13px;font-weight:600;text-align:center;padding:8px;border-radius:8px;margin-bottom:14px;}\n  #pn-home .cd-co{display:block;text-align:center;background:var(--accent);color:#fff;border-radius:999px;padding:15px;font-weight:700;text-decoration:none;}\n  #pn-home .cd-empty{text-align:center;color:#94A3B8;padding:60px 20px;}\n\n  /* sticky bar */\n  #pn-home .sticky{position:fixed;left:0;right:0;bottom:0;z-index:50;background:#fff;border-top:1px solid var(--border);box-shadow:0 -4px 20px rgba(0,0,0,.08);transform:translateY(110%);transition:transform .3s;}\n  #pn-home .sticky.show{transform:translateY(0);}\n  #pn-home .sticky-in{display:flex;align-items:center;justify-content:space-between;gap:16px;padding:12px 20px;max-width:1140px;margin:0 auto;}\n  #pn-home .sticky .sname{font-weight:800;font-size:15px;}\n  #pn-home .sticky .sprice{color:var(--accent);font-weight:800;}\n  #pn-home .sticky .btn{width:auto;padding:12px 26px;font-size:15px;}\n  @media(max-width:600px){#pn-home .sticky .sname{display:none;}}\n</style>\n\n<div id=\"pn-home\">\n\n  <!-- ===== ANNOUNCEMENT ===== -->\n  <div class=\"ann\"><div class=\"ann-track\">\n    {%- for i in (1..2) -%}\n      <span>🚚 FREE delivery on every order</span>\n      <span>✓ 30-day money-back guarantee</span>\n      <span>⭐ Loved by 1,200+ customers</span>\n    {%- endfor -%}\n  </div></div>\n\n  <!-- ===== HEADER ===== -->\n  <header class=\"hdr\"><div class=\"hdr-in\">\n    <a class=\"hdr-logo\" href=\"{{ routes.root_url }}\">PosturoNow</a>\n    <nav class=\"hdr-nav\">\n      <a href=\"#buy\">Shop</a>\n      <a href=\"#how\">How It Works</a>\n      <a href=\"#reviews\">Reviews</a>\n      <a href=\"#faq\">FAQ</a>\n    </nav>\n    <button class=\"hdr-cart\" onclick=\"pnCartOpen()\" aria-label=\"Cart\">\n      <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z\"/><path d=\"M3 6h18\"/><path d=\"M16 10a4 4 0 0 1-8 0\"/></svg>\n      <span class=\"hdr-count\" id=\"pn-count\">{{ cart.item_count }}</span>\n    </button>\n  </div></header>\n\n  <!-- ===== HERO ===== -->\n  <section class=\"hero\"><div class=\"wrap\"><div class=\"hero-grid\">\n    <div>\n      <span class=\"stars\">★★★★★</span> <span style=\"font-size:14px;color:#CBD5E1;\">4.9 · 1,200+ happy customers</span>\n      <h1>Sit Taller. Feel Better. Every Day.</h1>\n      <p class=\"sub\">The PosturoNow smart belt gives gentle support that keeps you aware of your upper-back and shoulder position — all day, effortlessly.</p>\n      <a href=\"#buy\" class=\"btn\">Shop Now — {{ cur.price | money }}</a>\n      <div class=\"badges\">\n        <span class=\"badge\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M12 2 4 5v6c0 5 3.5 8.5 8 11 4.5-2.5 8-6 8-11V5l-8-3z\"/></svg> Secure checkout</span>\n        <span class=\"badge\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M1 3h15v13H1zM16 8h4l3 3v5h-7\"/></svg> Free delivery</span>\n        <span class=\"badge\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><circle cx=\"12\" cy=\"12\" r=\"9\"/><path d=\"M9 12l2 2 4-4\"/></svg> 30-day guarantee</span>\n      </div>\n    </div>\n    <div>\n      {%- if p.featured_image -%}\n        <img class=\"hero-img\" src=\"{{ p.featured_image | image_url: width: 800 }}\" alt=\"{{ p.title | escape }}\">\n      {%- else -%}<div class=\"hero-img\"></div>{%- endif -%}\n    </div>\n  </div></div></section>\n\n  <!-- ===== TRUST ICONS ===== -->\n  <section class=\"sect alt\"><div class=\"wrap\">\n    <div class=\"trust\">\n      <div class=\"ti\"><div class=\"ico\">🚚</div><h3>Free Delivery</h3><p>On every order, no minimum.</p></div>\n      <div class=\"ti\"><div class=\"ico\">🛡️</div><h3>30-Day Guarantee</h3><p>Love it or your money back.</p></div>\n      <div class=\"ti\"><div class=\"ico\">🔒</div><h3>Secure Checkout</h3><p>Encrypted & protected.</p></div>\n      <div class=\"ti\"><div class=\"ico\">💬</div><h3>Friendly Support</h3><p>We reply within 24 hours.</p></div>\n    </div>\n  </div></section>\n\n  <!-- ===== PRODUCT BUY BLOCK ===== -->\n  <section class=\"sect\" id=\"buy\"><div class=\"wrap\"><div class=\"buy-grid\">\n    <div class=\"gallery\">\n      {%- if p.featured_image -%}\n        <img class=\"main\" id=\"pn-main\" src=\"{{ p.featured_image | image_url: width: 800 }}\" alt=\"{{ p.title | escape }}\">\n        {%- if p.images.size > 1 -%}\n          <div class=\"thumbs\">\n            {%- for img in p.images limit:5 -%}\n              <img src=\"{{ img | image_url: width:160 }}\" class=\"{% if forloop.first %}active{% endif %}\" onclick=\"pnSwap('{{ img | image_url: width:800 }}',this)\" alt=\"\">\n            {%- endfor -%}\n          </div>\n        {%- endif -%}\n      {%- else -%}<div class=\"main\"></div>{%- endif -%}\n    </div>\n    <div class=\"buy\">\n      <span class=\"stars\">★★★★★</span> <span style=\"color:#94A3B8;font-size:13px;font-weight:600;\">1,200+ reviews</span>\n      <h2>{{ p.title | default: 'Posture Support Belt' }}</h2>\n      <p style=\"color:var(--text);margin:0 0 4px;\">{{ p.description | strip_html | truncatewords: 35 }}</p>\n      {%- if p != blank -%}\n        {%- form 'product', p, id:'pn-form' -%}\n          <div class=\"price-row\">\n            <span class=\"price\" id=\"pn-price\">{{ cur.price | money }}</span>\n            {%- if cur.compare_at_price > cur.price -%}\n              <span class=\"compare\">{{ cur.compare_at_price | money }}</span>\n              {%- assign diff = cur.compare_at_price | minus: cur.price -%}\n              {%- assign pct = diff | times:100 | divided_by: cur.compare_at_price -%}\n              <span class=\"save\">SAVE {{ pct }}%</span>\n            {%- endif -%}\n          </div>\n          <div class=\"ship\">✓ Free delivery — ships in 24h</div>\n          {%- unless p.has_only_default_variant -%}\n            {%- for opt in p.options_with_values -%}\n              <div class=\"opt\"><label>{{ opt.name }}</label>\n                <div class=\"swatches\">\n                  {%- for val in opt.values -%}\n                    <div class=\"swatch {% if opt.selected_value == val %}active{% endif %}\" data-value=\"{{ val | escape }}\" onclick=\"pnOpt(this,{{ forloop.parentloop.index0 }})\">{{ val }}</div>\n                  {%- endfor -%}\n                </div>\n              </div>\n            {%- endfor -%}\n          {%- endunless -%}\n          <select name=\"id\" id=\"pn-sel\" style=\"display:none;\">\n            {%- for v in p.variants -%}\n              <option value=\"{{ v.id }}\" {% if v == cur %}selected{% endif %} {% unless v.available %}disabled{% endunless %} data-price=\"{{ v.price | money }}\" {% for o in v.options %}data-opt{{ forloop.index0 }}=\"{{ o | escape }}\"{% endfor %}>{{ v.title }}</option>\n            {%- endfor -%}\n          </select>\n          <div class=\"opt\"><label>Quantity</label>\n            <div class=\"qty\"><button type=\"button\" onclick=\"pnQty(-1)\">−</button><input type=\"number\" name=\"quantity\" id=\"pn-qty\" value=\"1\" min=\"1\"><button type=\"button\" onclick=\"pnQty(1)\">+</button></div>\n          </div>\n          <button type=\"submit\" class=\"btn\" id=\"pn-atc\" {% unless cur.available %}disabled{% endunless %}>{% if cur.available %}Add to Cart — {{ cur.price | money }}{% else %}Sold Out{% endif %}</button>\n        {%- endform -%}\n      {%- else -%}\n        <p style=\"color:#b91c1c;font-weight:600;\">⚠ No product found. Set the handle at the top of this Custom Liquid block.</p>\n      {%- endif -%}\n    </div>\n  </div></div></section>\n\n  <!-- ===== HOW IT WORKS / SPLIT ===== -->\n  <section class=\"sect alt\" id=\"how\"><div class=\"wrap\"><div class=\"split\">\n    <div>\n      {%- if p.images[1] -%}<img src=\"{{ p.images[1] | image_url: width:700 }}\" alt=\"\">{%- elsif p.featured_image -%}<img src=\"{{ p.featured_image | image_url: width:700 }}\" alt=\"\">{%- endif -%}\n    </div>\n    <div>\n      <span class=\"band\" style=\"color:var(--accent);font-weight:700;font-size:13px;letter-spacing:1px;text-transform:uppercase;\">Why It Works</span>\n      <h2 class=\"h2\" style=\"text-align:left;\">Comfortable Enough to Wear All Day</h2>\n      <p style=\"color:var(--text);\">Adjustable, breathable, and discreet under clothing — built to fit into your real routine.</p>\n      <ul class=\"feat\">\n        <li><span class=\"ck\">✓</span> Fully adjustable fit for all body types</li>\n        <li><span class=\"ck\">✓</span> Lightweight and breathable material</li>\n        <li><span class=\"ck\">✓</span> Discreet under shirts and jackets</li>\n        <li><span class=\"ck\">✓</span> Works best with movement and stretching</li>\n      </ul>\n      <a href=\"#buy\" class=\"btn\" style=\"margin-top:22px;\">Get Yours</a>\n    </div>\n  </div></div></section>\n\n  <!-- ===== RICH TEXT BAND ===== -->\n  <section class=\"sect band\"><div class=\"wrap\">\n    <span class=\"eyebrow\">Our Promise</span>\n    <h2>Better Posture, Better Days</h2>\n    <p>PosturoNow is designed to support your posture and help you build healthier habits — gently, comfortably, and every day.</p>\n  </div></section>\n\n  <!-- ===== REVIEWS ===== -->\n  <section class=\"sect alt\" id=\"reviews\"><div class=\"wrap\">\n    <h2 class=\"h2\">Loved by Thousands</h2>\n    <p class=\"lead\">Real results from real customers.</p>\n    <div class=\"reviews\">\n      <div class=\"rev\"><span class=\"stars\">★★★★★</span><p>\"I wear it at my desk every day and my upper back feels so much better.\"</p><div class=\"who\">Sarah M.</div><span class=\"ver\">✓ Verified buyer</span></div>\n      <div class=\"rev\"><span class=\"stars\">★★★★★</span><p>\"Comfortable, easy to adjust, and you can't see it under a shirt.\"</p><div class=\"who\">James K.</div><span class=\"ver\">✓ Verified buyer</span></div>\n      <div class=\"rev\"><span class=\"stars\">★★★★★</span><p>\"Great reminder to stop slouching while I work from home.\"</p><div class=\"who\">Lina H.</div><span class=\"ver\">✓ Verified buyer</span></div>\n    </div>\n  </div></section>\n\n  <!-- ===== FAQ ===== -->\n  <section class=\"sect\" id=\"faq\"><div class=\"wrap\">\n    <h2 class=\"h2\">Frequently Asked Questions</h2>\n    <div class=\"faq\" style=\"margin-top:28px;\">\n      <div class=\"faq-item\"><button class=\"faq-q\" onclick=\"pnFaq(this)\">Is it comfortable to wear? <span class=\"pl\">+</span></button><div class=\"faq-a\">Yes — it's lightweight and adjustable, designed to be worn comfortably during your daily routine.</div></div>\n      <div class=\"faq-item\"><button class=\"faq-q\" onclick=\"pnFaq(this)\">How long should I wear it each day? <span class=\"pl\">+</span></button><div class=\"faq-a\">Start with 1–2 hours a day and increase gradually. It works best combined with movement and stretching.</div></div>\n      <div class=\"faq-item\"><button class=\"faq-q\" onclick=\"pnFaq(this)\">Will it fit me? <span class=\"pl\">+</span></button><div class=\"faq-a\">The fully adjustable straps fit most body types comfortably.</div></div>\n      <div class=\"faq-item\"><button class=\"faq-q\" onclick=\"pnFaq(this)\">What is your return policy? <span class=\"pl\">+</span></button><div class=\"faq-a\">We offer a 30-day money-back guarantee. If you're not satisfied, contact us for a full refund.</div></div>\n    </div>\n  </div></section>\n\n  <!-- ===== FINAL CTA ===== -->\n  <section class=\"sect\"><div class=\"wrap\"><div class=\"cta\">\n    <h2>Start Sitting Taller Today</h2>\n    <p>Join thousands improving their posture with PosturoNow. Free delivery and a 30-day money-back guarantee.</p>\n    <a href=\"#buy\" class=\"btn\" style=\"width:auto;padding:16px 44px;\">Add to Cart</a>\n  </div></div></section>\n\n  <!-- ===== FOOTER ===== -->\n  <footer class=\"ft\"><div class=\"wrap\">\n    <div class=\"ft-grid\">\n      <div>\n        <div class=\"name\">PosturoNow</div>\n        <p class=\"tag\">Gentle posture support for your everyday routine.</p>\n      </div>\n      <div>\n        <h4>Shop</h4>\n        <ul><li><a href=\"#buy\">Posture Belt</a></li><li><a href=\"#reviews\">Reviews</a></li><li><a href=\"#faq\">FAQ</a></li></ul>\n      </div>\n      <div>\n        <h4>Help</h4>\n        <ul><li><a href=\"/pages/contact\">Contact</a></li><li><a href=\"/pages/shipping\">Shipping</a></li><li><a href=\"/pages/returns\">Returns</a></li></ul>\n      </div>\n      <div class=\"news\">\n        <h4>Stay in touch</h4>\n        {%- form 'customer' -%}\n          <input type=\"hidden\" name=\"contact[tags]\" value=\"newsletter,footer\">\n          <input type=\"email\" name=\"contact[email]\" placeholder=\"Your email\" required>\n          <button type=\"submit\">Subscribe</button>\n          {%- if form.posted_successfully? -%}<p style=\"color:#86efac;margin-top:8px;font-size:13px;\">Subscribed — thank you!</p>{%- endif -%}\n        {%- endform -%}\n      </div>\n    </div>\n    <div class=\"ft-bottom\">\n      <p>© {{ 'now' | date: '%Y' }} PosturoNow. All rights reserved.</p>\n      <div class=\"ft-pay\"><span>VISA</span><span>MASTERCARD</span><span>AMEX</span><span>PAYPAL</span><span>APPLE PAY</span></div>\n    </div>\n  </div></footer>\n\n  <!-- ===== STICKY ADD-TO-CART ===== -->\n  {%- if p != blank -%}\n  <div class=\"sticky\" id=\"pn-sticky\"><div class=\"sticky-in\">\n    <div><span class=\"sname\">{{ p.title }}</span> <span class=\"sprice\" id=\"pn-sprice\">{{ cur.price | money }}</span></div>\n    <button type=\"submit\" form=\"pn-form\" class=\"btn\">Add to Cart</button>\n  </div></div>\n  {%- endif -%}\n\n  <!-- ===== POPUP ===== -->\n  <div class=\"pop\" id=\"pn-pop\"><div class=\"pop-box\">\n    <button class=\"pop-close\" onclick=\"pnPopClose()\">×</button>\n    <h3>Get 10% Off</h3>\n    <p>Sign up and save 10% on your first PosturoNow order.</p>\n    {%- form 'customer' -%}\n      <input type=\"hidden\" name=\"contact[tags]\" value=\"newsletter,popup\">\n      <input type=\"email\" name=\"contact[email]\" placeholder=\"Enter your email\" required>\n      <button type=\"submit\" class=\"btn\">Claim My 10%</button>\n    {%- endform -%}\n  </div></div>\n\n  <!-- ===== PRIVACY BANNER ===== -->\n  <div class=\"priv\" id=\"pn-priv\"><div class=\"priv-in\">\n    <p>We use cookies to improve your experience and analyze site traffic.</p>\n    <div class=\"priv-btns\">\n      <button class=\"priv-dec\" onclick=\"pnConsent('declined')\">Decline</button>\n      <button class=\"priv-acc\" onclick=\"pnConsent('accepted')\">Accept</button>\n    </div>\n  </div></div>\n\n  <!-- ===== CART DRAWER ===== -->\n  <div class=\"cd-ov\" id=\"pn-cd-ov\" onclick=\"pnCartClose()\"></div>\n  <aside class=\"cd\" id=\"pn-cd\" aria-label=\"Cart\">\n    <div class=\"cd-head\"><h3>Your Cart (<span id=\"pn-cd-count\">{{ cart.item_count }}</span>)</h3><button class=\"cd-close\" onclick=\"pnCartClose()\">×</button></div>\n    <div class=\"cd-items\" id=\"pn-cd-items\"></div>\n    <div class=\"cd-foot\" id=\"pn-cd-foot\"></div>\n  </aside>\n\n</div>\n\n<script>\n(function(){\n  var FREE_SHIP_THRESHOLD = 0; // set in cents, e.g. 5000 for $50; 0 = off\n  function fmt(c){ return \"$\"+(c/100).toFixed(2); }\n\n  /* gallery */\n  window.pnSwap=function(src,el){ document.getElementById(\"pn-main\").src=src; el.parentNode.querySelectorAll(\"img\").forEach(function(i){i.classList.remove(\"active\");}); el.classList.add(\"active\"); };\n  window.pnQty=function(d){ var i=document.getElementById(\"pn-qty\"); i.value=Math.max(1,(parseInt(i.value)||1)+d); };\n\n  /* variants */\n  var sel=document.getElementById(\"pn-sel\");\n  window.pnOpt=function(el,gi){\n    el.parentNode.querySelectorAll(\".swatch\").forEach(function(s){s.classList.remove(\"active\");});\n    el.classList.add(\"active\");\n    if(!sel) return;\n    var groups=document.querySelectorAll(\"#pn-home .swatches\"),chosen=[];\n    groups.forEach(function(g){var a=g.querySelector(\".swatch.active\");chosen.push(a?a.getAttribute(\"data-value\"):null);});\n    for(var i=0;i<sel.options.length;i++){\n      var ok=true;\n      for(var k=0;k<chosen.length;k++){ if(chosen[k]&&sel.options[i].getAttribute(\"data-opt\"+k)!==chosen[k]){ok=false;break;} }\n      if(ok){ sel.selectedIndex=i; var pr=sel.options[i].getAttribute(\"data-price\"),dis=sel.options[i].disabled;\n        document.getElementById(\"pn-price\").textContent=pr;\n        var sp=document.getElementById(\"pn-sprice\"); if(sp) sp.textContent=pr;\n        var b=document.getElementById(\"pn-atc\"); if(b){ b.disabled=dis; b.textContent=dis?\"Sold Out\":(\"Add to Cart — \"+pr); } break; }\n    }\n  };\n\n  /* faq */\n  window.pnFaq=function(b){ b.parentNode.classList.toggle(\"open\"); };\n\n  /* sticky bar */\n  var atc=document.getElementById(\"pn-atc\"),sticky=document.getElementById(\"pn-sticky\");\n  if(atc&&sticky){ window.addEventListener(\"scroll\",function(){ var r=atc.getBoundingClientRect(); sticky.classList.toggle(\"show\", r.bottom<0); },{passive:true}); }\n\n  /* popup */\n  window.pnPopClose=function(){ document.getElementById(\"pn-pop\").classList.remove(\"show\"); localStorage.setItem(\"pn-popup\",Date.now()); };\n  setTimeout(function(){ var last=localStorage.getItem(\"pn-popup\"); if(!last||(Date.now()-last)>7*864e5) document.getElementById(\"pn-pop\").classList.add(\"show\"); },5000);\n  document.getElementById(\"pn-pop\").addEventListener(\"click\",function(e){ if(e.target.id===\"pn-pop\") pnPopClose(); });\n\n  /* privacy */\n  window.pnConsent=function(c){ localStorage.setItem(\"pn-consent\",c); if(window.Shopify&&Shopify.customerPrivacy){try{Shopify.customerPrivacy.setTrackingConsent(c===\"accepted\");}catch(e){}} document.getElementById(\"pn-priv\").classList.remove(\"show\"); };\n  if(!localStorage.getItem(\"pn-consent\")) document.getElementById(\"pn-priv\").classList.add(\"show\");\n\n  /* cart drawer */\n  var ov=document.getElementById(\"pn-cd-ov\"),cd=document.getElementById(\"pn-cd\"),itemsEl=document.getElementById(\"pn-cd-items\"),footEl=document.getElementById(\"pn-cd-foot\");\n  function render(cart){\n    document.getElementById(\"pn-cd-count\").textContent=cart.item_count;\n    var hc=document.getElementById(\"pn-count\"); if(hc) hc.textContent=cart.item_count;\n    if(cart.item_count===0){ itemsEl.innerHTML='<div class=\"cd-empty\"><p>Your cart is empty.</p></div>'; footEl.innerHTML=\"\"; return; }\n    var h=\"\";\n    cart.items.forEach(function(it,i){\n      h+='<div class=\"cd-item\"><img src=\"'+(it.image?it.image.replace(/(\\.[a-z]+)(\\?|$)/i,\"_120x$1$2\"):\"\")+'\" alt=\"\">'\n       +'<div style=\"flex:1\"><a class=\"cd-title\" href=\"'+it.url+'\">'+it.product_title+'</a>'\n       +(it.variant_title?'<div style=\"font-size:12px;color:#94A3B8\">'+it.variant_title+'</div>':'')\n       +'<div class=\"cd-qty\"><button onclick=\"pnCartChange('+(i+1)+','+(it.quantity-1)+')\">−</button><span>'+it.quantity+'</span><button onclick=\"pnCartChange('+(i+1)+','+(it.quantity+1)+')\">+</button></div>'\n       +'<button class=\"cd-rm\" onclick=\"pnCartChange('+(i+1)+',0)\">Remove</button></div>'\n       +'<div style=\"font-weight:700\">'+fmt(it.final_line_price)+'</div></div>';\n    });\n    itemsEl.innerHTML=h;\n    var free=\"\";\n    if(FREE_SHIP_THRESHOLD>0){ free=cart.total_price>=FREE_SHIP_THRESHOLD?'<div class=\"cd-free\">🎉 You unlocked FREE delivery!</div>':'<div class=\"cd-free\">Add '+fmt(FREE_SHIP_THRESHOLD-cart.total_price)+' more for FREE delivery</div>'; }\n    footEl.innerHTML=free+'<div class=\"cd-sub\"><span>Subtotal</span><span>'+fmt(cart.total_price)+'</span></div><p style=\"font-size:12px;color:#94A3B8;margin:0 0 14px\">Shipping & taxes calculated at checkout.</p><a class=\"cd-co\" href=\"/checkout\">Checkout</a>';\n  }\n  function refresh(){ fetch(\"/cart.js\").then(function(r){return r.json();}).then(render); }\n  window.pnCartOpen=function(){ ov.classList.add(\"open\"); cd.classList.add(\"open\"); document.body.style.overflow=\"hidden\"; refresh(); };\n  window.pnCartClose=function(){ ov.classList.remove(\"open\"); cd.classList.remove(\"open\"); document.body.style.overflow=\"\"; };\n  window.pnCartChange=function(line,qty){ fetch(\"/cart/change.js\",{method:\"POST\",headers:{\"Content-Type\":\"application/json\"},body:JSON.stringify({line:line,quantity:qty})}).then(function(r){return r.json();}).then(render); };\n  document.addEventListener(\"submit\",function(e){\n    var f=e.target;\n    if(f.id===\"pn-form\"){ e.preventDefault(); fetch(\"/cart/add.js\",{method:\"POST\",body:new FormData(f)}).then(function(r){return r.json();}).then(function(){ pnCartOpen(); }); }\n  });\n  refresh();\n})();\n</script>",
        "add_vertical_spacing": true,
        "background_type": "full_width",
        "background": "rgba(0,0,0,0)",
        "text_color": "rgba(0,0,0,0)"
      }
    }
